#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID TASK_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 3 ]] || usage
load_harness_env "$1"
task_id="$2"
task_file="$3"
ensure_project
trace_init manager_publish_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
[[ -f "$task_file" ]] || die "task file does not exist: $task_file"
acquire_project_lock
dir="$(project_dir)"

stagnant_revision_limit_reached()
{
	local root="$1"
	local -a rejected_files
	local file zero_count=0

	shopt -s nullglob
	rejected_files=("$dir/archive/$PROJECT-task-$root-revision-"*.rejected.md)
	(( ${#rejected_files[@]} >= HARNESS_MAX_STAGNANT_REVISIONS_PER_TASK )) || return 1

	# The standard NN revision suffix makes lexical ordering chronological.
	for (( i=${#rejected_files[@]} - 1; i>=0 && zero_count < HARNESS_MAX_STAGNANT_REVISIONS_PER_TASK; i-- )); do
		file="${rejected_files[i]}"
		if grep -Fqx 'Improvement-Percent: 0%' "$file"; then
			zero_count=$((zero_count + 1))
		else
			return 1
		fi
	done
	(( zero_count == HARNESS_MAX_STAGNANT_REVISIONS_PER_TASK ))
}

# Revisions use ROOT-revision-NN. They may continue while a cheap worker is
# improving; only a sustained zero-gain run requires human intervention.
if [[ "$task_id" =~ ^(.+)-revision-([0-9]+)$ ]]; then
	revision_root="${BASH_REMATCH[1]}"
	if stagnant_revision_limit_reached "$revision_root"; then
		die "no improvement in the last $HARNESS_MAX_STAGNANT_REVISIONS_PER_TASK revisions of $revision_root; human intervention required"
	fi
fi

base="$(task_base "$task_id")"
ready="$dir/tasks/$base.ready.md"
running="$dir/running/$base.running.md"
result="$dir/results/$base.result.md"
accepted="$dir/archive/$base.accepted.md"
aborted="$dir/control/$base.abort.md"

[[ ! -e "$ready" ]] || die "task already ready: $task_id"
[[ ! -e "$running" ]] || die "task already running: $task_id"
[[ ! -e "$result" ]] || die "task already has a result: $task_id"
[[ ! -e "$accepted" ]] || die "task already accepted: $task_id"
[[ ! -e "$aborted" ]] || die "task is aborted: $task_id"

tmp="$dir/tasks/$base.ready.tmp.$$"
install -m 600 "$task_file" "$tmp"
mv "$tmp" "$ready"

log_event "TASK_PUBLISHED task=$task_id file=$ready"
trace_event TASK_PUBLISHED "task_id=$task_id" "source_file=$task_file" "ready_file=$ready"
printf '%s\n' "$ready"
