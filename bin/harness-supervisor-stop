#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
trace_init manager_supervisor_stop
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
pid_file="$(project_dir)/control/supervisor.pid"
[[ -f "$pid_file" ]] || {
	trace_event SUPERVISOR_STOP_SKIPPED "reason=not_running"
	printf 'Supervisor is not running.\n'
	exit 0
}
pid="$(cat "$pid_file")"
if kill -0 "$pid" 2>/dev/null; then
	trace_event SUPERVISOR_STOP_SIGNAL "pid=$pid" "signal=TERM"
	kill "$pid"
	for _ in $(seq 1 50); do
		kill -0 "$pid" 2>/dev/null || break
		sleep 0.1
	done
fi
if kill -0 "$pid" 2>/dev/null; then
	trace_event SUPERVISOR_STOP_DEFERRED "pid=$pid" "reason=active_child"
	printf 'Supervisor PID %s is waiting for an active child and will stop after it exits.\n' "$pid" >&2
	exit 3
fi
rm -f "$pid_file" "$(project_dir)/control/supervisor.env-file"
trace_event SUPERVISOR_STOPPED "pid=$pid"
printf 'Supervisor stopped.\n'
