#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID SESSION RESULT_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 4 ]] || usage
load_harness_env "$1"
task_id="$2"
session="$3"
result_file="$4"

ensure_project
ensure_session "$session"
trace_init worker_complete_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
[[ -f "$result_file" ]] || die "result file does not exist: $result_file"
acquire_project_lock

dir="$(project_dir)"
base="$(task_base "$task_id")"
running="$dir/running/$base.running.md"
lease="$dir/control/$base.lease"
abort="$dir/control/$base.abort.md"
result="$dir/results/$base.result.md"
assignment_archive="$dir/archive/$base.assignment.md"

[[ ! -f "$abort" ]] || {
	printf 'Task %s has been aborted; completion refused.\n' "$task_id" >&2
	exit 125
}
[[ -f "$running" ]] || die "task is not running: $task_id"
[[ -f "$lease" ]] || die "lease is missing: $task_id"
[[ ! -e "$result" ]] || die "result already exists: $task_id"

owner="$(lease_value "$lease" owner)"
[[ "$owner" == "$session" ]] || die "task is owned by $owner, not $session"

tmp="$dir/results/$base.result.tmp.$$"
metadata_tmp="$dir/results/$base.result.metadata.tmp.$$"
normalized_fields=()
normalize_reported_status=0
required_headings=(
	'## Summary'
	'## Modified files'
	'## Implemented behavior'
	'## Validation performed'
	'## Deviations from assignment'
	'## Remaining concerns'
	'## Worker assessment'
)

# Completion is the only supported publication boundary, so canonicalize
# harmless report-shape omissions here before the manager can observe the
# result. The worker-authored text remains intact and the manager must still
# independently verify every claimed increment. A conflicting task identity
# remains a hard protocol error. Worker-authored status words such as BLOCKED
# describe the assessment, not the completion transaction, so preserve them
# under Worker-Reported-Status and publish the canonical transaction status.
while IFS= read -r reported_task_id; do
	[[ "$reported_task_id" == "$task_id" ]] ||
		die "result Task-ID is $reported_task_id, expected $task_id"
done < <(sed -n 's/^Task-ID:[[:space:]]*//p' "$result_file")
while IFS= read -r reported_status; do
	[[ "$reported_status" == COMPLETED ]] || normalize_reported_status=1
done < <(sed -n 's/^Status:[[:space:]]*//p' "$result_file")

if (( normalize_reported_status == 1 )); then
	sed 's/^Status:/Worker-Reported-Status:/' "$result_file" > "$tmp"
	chmod 600 "$tmp"
	normalized_fields+=('Worker-Reported-Status')
else
	install -m 600 "$result_file" "$tmp"
fi
if ! grep -Fqx -- "Task-ID: $task_id" "$tmp" ||
	! grep -Fqx -- 'Status: COMPLETED' "$tmp"; then
	{
		if ! grep -Fqx -- "Task-ID: $task_id" "$tmp"; then
			printf 'Task-ID: %s\n' "$task_id"
			normalized_fields+=('Task-ID')
		fi
		if ! grep -Fqx -- 'Status: COMPLETED' "$tmp"; then
			printf 'Status: COMPLETED\n'
			normalized_fields+=('Status')
		fi
		printf '\n'
		cat "$tmp"
	} > "$metadata_tmp"
	chmod 600 "$metadata_tmp"
	mv "$metadata_tmp" "$tmp"
fi
for heading in "${required_headings[@]}"; do
	if ! grep -Fqx -- "$heading" "$tmp"; then
		{
			printf '\n%s\n\n' "$heading"
			printf 'Not separately structured in the worker-authored report; '
			printf 'the original report content is preserved above for independent manager review.\n'
		} >> "$tmp"
		normalized_fields+=("${heading#\#\# }")
	fi
done
if (( ${#normalized_fields[@]} > 0 )); then
	normalized_list="$(IFS=,; printf '%s' "${normalized_fields[*]}")"
	printf '\n<!-- Harness-normalized worker-result fields: %s -->\n' "$normalized_list" >> "$tmp"
fi

mv "$running" "$assignment_archive"
rm -f "$lease"
mv "$tmp" "$result"

if (( ${#normalized_fields[@]} > 0 )); then
	log_event "WORKER_RESULT_NORMALIZED task=$task_id owner=$session fields=$(printf '%q' "$normalized_list")"
	trace_event WORKER_RESULT_NORMALIZED "task_id=$task_id" "session=$session" "fields=$normalized_list"
fi
log_event "TASK_COMPLETED task=$task_id owner=$session result=$result"
trace_event TASK_COMPLETED "task_id=$task_id" "session=$session" "input_result=$result_file" "stored_result=$result" "assignment_archive=$assignment_archive"
printf '%s\n' "$result"
