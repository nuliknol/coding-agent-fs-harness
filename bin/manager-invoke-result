#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 2 ]] || usage
load_harness_env "$1"
task_id="$2"
ensure_project
require_manager_configuration
require_manager_codex
trace_init manager_invoke_result
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
write_manager_snapshot

project_path="$(project_dir)"
thread_file="$project_path/control/manager.thread"
[[ -f "$thread_file" ]] || die 'manager thread is not registered; run manager-bootstrap'
thread_id="$(kv_file_value "$thread_file" thread_id)"
base="$(task_base "$task_id")"
result="$project_path/results/$base.result.md"
running="$project_path/running/$base.running.md"
lease="$project_path/control/$base.lease"
assignment_archive="$project_path/archive/$base.assignment.md"
accepted="$project_path/archive/$base.accepted.md"
checkpointed="$project_path/archive/$base.checkpointed.md"
rejected="$project_path/archive/$base.rejected.md"
blocked="$project_path/archive/$base.blocked.md"
pending_exit_status=3
[[ -f "$result" ]] || die "result file does not exist: $result"
[[ ! -e "$running" ]] || die "result is not committed; running assignment still exists: $running"
[[ ! -e "$lease" ]] || die "result is not committed; worker lease still exists: $lease"
[[ -f "$assignment_archive" ]] || die "result is not committed; archived assignment is missing: $assignment_archive"
initialize_task_progress "$task_id" "$assignment_archive"
task_root="$(task_root_id "$task_id")"
progress_file="$(task_progress_file "$task_root")"
root_assignment_file="$(task_root_assignment_file "$task_root")"
criteria_definition_file="$(task_criteria_definition_file "$task_root")"
criterion_ledger_file="$(task_criterion_ledger_file "$task_root")"
first_unmet_criterion="$(task_first_unmet_criterion "$task_root" 2>/dev/null || true)"
current_progress="$(task_progress_percent "$task_root")"
closure_mode_active=0
if (( HARNESS_CLOSURE_MODE_ENABLED == 1 )) &&
	[[ "$task_id" != "$task_root" ]] &&
	(( current_progress >= HARNESS_CLOSURE_MODE_MIN_PROGRESS && current_progress < 100 )); then
	closure_mode_active=1
fi
development_policy_file="$REPOSITORY/design/development-policy.txt"
[[ -f "$development_policy_file" ]] || development_policy_file=""
project_plan_definition="$(project_plan_definition_file)"
project_plan_state="$(project_plan_state_file)"
project_plan_exists || die 'project plan is missing; cannot review a task outside the specification plan'

prompt_file="$project_path/control/$base.manager-review.prompt.md"
cat > "$prompt_file.tmp.$$" <<PROMPT
A worker result is ready for review.

ENV_FILE=$HARNESS_ENV_FILE
PROJECT=$PROJECT
PROJECT_TMP_DIR=$PROJECT_TMP_DIR
TASK_ID=$task_id
RESULT_FILE=$result
TASK_ROOT=$task_root
ROOT_ASSIGNMENT_FILE=$root_assignment_file
PROGRESS_FILE=$progress_file
CRITERIA_DEFINITION_FILE=$criteria_definition_file
CRITERION_LEDGER_FILE=$criterion_ledger_file
FIRST_UNMET_CRITERION=$first_unmet_criterion
CURRENT_PROGRESS_PERCENT=$current_progress
PROJECT_PLAN_FILE=$project_plan_definition
PROJECT_PLAN_STATE_FILE=$project_plan_state
PROJECT_PROGRESS_PERCENT=$(project_plan_progress_percent)
DEVELOPMENT_POLICY_FILE=$development_policy_file
SPECIFICATION=$SPECIFICATION
REPOSITORY=$REPOSITORY
HARNESS_BIN=$HARNESS_BIN
CLOSURE_MODE_ACTIVE=$closure_mode_active
CLOSURE_MODE_ELIGIBLE_ON_REJECTION=$([[ "$HARNESS_CLOSURE_MODE_ENABLED" == 1 && "$current_progress" -ge "$HARNESS_CLOSURE_MODE_MIN_PROGRESS" && "$current_progress" -lt 100 ]] && printf 1 || printf 0)
CLOSURE_MAX_FIXES=$HARNESS_CLOSURE_MODE_MAX_FIXES
CLOSURE_MAX_SMOKE_RUNS=$HARNESS_CLOSURE_MODE_MAX_SMOKE_RUNS
MAX_ROOT_ATTEMPTS=$HARNESS_MAX_ROOT_ATTEMPTS
MAX_ZERO_GAIN_WINDOW=$HARNESS_MAX_ZERO_GAIN_WINDOW
MAX_CHECKPOINTS_WITHOUT_CRITERION=$HARNESS_MAX_CHECKPOINTS_WITHOUT_CRITERION

Read $HARNESS_HOME/prompts/manager-agent-event-driven.md and follow it. Read DEVELOPMENT_POLICY_FILE when present, then PROJECT_PLAN_FILE, PROJECT_PLAN_STATE_FILE, ROOT_ASSIGNMENT_FILE, PROGRESS_FILE, CRITERIA_DEFINITION_FILE, and CRITERION_LEDGER_FILE when present before reviewing this result. Reconcile cumulative root progress and project progress against the actual repository; do not reset completed work after a restart. Write any review note and any next or revision task file under PROJECT_TMP_DIR. Every harness command must receive ENV_FILE as its first argument. Checkpoint a correct verified increment that does not complete the root; accept only when the entire root passes; reject only a faulty, regressive, or unverified increment. Any ordinary continuation must set Target-Criterion to FIRST_UNMET_CRITERION. Inspect the command's returned path and do not publish a continuation when it ends in .needs-replan.md, .needs-human.md, or .blocked.md; the supervisor owns automatic replanning. When closure mode is eligible, author the continuation for the bounded multi-attempt closure policy rather than imposing an exactly-once smoke restriction. Acceptance completes only the current project-plan item; if project items remain, publish exactly one task for the next item. Then terminate immediately. Do not wait, sleep, poll, watch the filesystem, or call manager-wait-result.
PROMPT
if codex_model_requires_narrow_prompt "$MANAGER_MODEL"; then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Context: authorized local development in my own repository. Task type: benign software engineering. Do not perform offensive security, credential extraction, vulnerability exploitation, malware behavior, unauthorized access, network scanning, or bypassing security controls. Use only the listed local project files needed for the requested implementation: RESULT_FILE, SPECIFICATION, and files explicitly necessary to review that bounded result.
PROMPT
fi
chmod 600 "$prompt_file.tmp.$$"
mv "$prompt_file.tmp.$$" "$prompt_file"

attempt=1
provider_retries=0
quota_waits=0
status=0
json_log=""
stderr_log=""
last_message=""
classification=""
fallback_stage=0
current_model="$MANAGER_MODEL"

manager_action_committed()
{
	[[ -f "$accepted" || -f "$checkpointed" || -f "$rejected" || -f "$blocked" ]]
}

while true; do
	stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
	attempt_label="$(printf '%03d' "$attempt")"
	json_log="$project_path/logs/manager-review-$task_id-$stamp-attempt-$attempt_label.jsonl"
	stderr_log="$project_path/logs/manager-review-$task_id-$stamp-attempt-$attempt_label.stderr.log"
	last_message="$project_path/logs/manager-review-$task_id-$stamp-attempt-$attempt_label.md"

	log_event "MANAGER_REVIEW_STARTED task=$task_id thread_id=$thread_id attempt=$attempt"
	trace_event MANAGER_REVIEW_ATTEMPT "task_id=$task_id" "attempt=$attempt" "thread_id=$thread_id" "json_log=$json_log" "last_message=$last_message"
	set +e
	trace_event CODEX_EXEC_START "role=manager_review" "task_id=$task_id" "attempt=$attempt" "thread_id=$thread_id" "json_log=$json_log" "last_message=$last_message" "model=$MANAGER_MODEL"
	"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" manager_review "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$last_message" resume "$thread_id"
	status=$?
	set -e
	classification="$(kv_file_value "${json_log%.jsonl}.classification" classification 2>/dev/null || true)"
	trace_event CODEX_EXEC_END "role=manager_review" "task_id=$task_id" "attempt=$attempt" "status=$status" "json_log=$json_log" "last_message=$last_message"

	if (( status == 0 )); then
		if manager_action_committed; then
			log_event "MANAGER_REVIEW_FINISHED task=$task_id attempt=$attempt"
			trace_event MANAGER_REVIEW_COMMITTED "task_id=$task_id" "attempt=$attempt" "status=$status"
			printf 'Manager review turn completed and exited for task %s.\n' "$task_id"
			exit 0
		fi

		log_event "MANAGER_REVIEW_LEFT_PENDING task=$task_id attempt=$attempt"
		trace_event MANAGER_REVIEW_PENDING "task_id=$task_id" "attempt=$attempt"
		printf 'Manager review exited without accepting, checkpointing, or rejecting task %s.\n' "$task_id" >&2
		exit "$pending_exit_status"
	fi

	# A manager command may have committed an accept/checkpoint/reject immediately before
	# the API stream failed. Never repeat a committed manager action.
	if manager_action_committed; then
		log_event "MANAGER_REVIEW_FINISHED task=$task_id attempt=$attempt outcome=action_committed_before_process_failure status=$status"
		trace_event MANAGER_REVIEW_COMMITTED_AFTER_FAILURE "task_id=$task_id" "attempt=$attempt" "status=$status"
		printf 'Manager action for task %s was committed before the Codex process failed.\n' "$task_id"
		exit 0
	fi

	retry_kind="$(codex_provider_retry_kind "$classification" 2>/dev/null || true)"
	if [[ -n "$retry_kind" ]]; then
		retry_delay="$(codex_provider_retry_delay "$classification")"
		provider_retries=$((provider_retries + 1))
		[[ "$retry_kind" != quota ]] || quota_waits=$((quota_waits + 1))
		log_event "MANAGER_PROVIDER_WAIT task=$task_id thread_id=$thread_id kind=$retry_kind attempt=$attempt retry=$provider_retries delay_seconds=$retry_delay classification=$classification"
		if [[ "$retry_kind" == quota ]]; then
			printf 'Manager review for task %s has no provider quota; result and thread are preserved. Checking again in %s seconds (quota wait %s).\n' "$task_id" "$retry_delay" "$quota_waits" >&2
		else
			printf 'Manager review for task %s hit a transient provider/network failure; retrying in %s seconds.\n' "$task_id" "$retry_delay" >&2
		fi
		sleep "$retry_delay"

		if manager_action_committed; then
			log_event "MANAGER_REVIEW_FINISHED task=$task_id attempt=$attempt outcome=action_committed_during_provider_wait"
			trace_event MANAGER_REVIEW_COMMITTED_DURING_RETRY_WAIT "task_id=$task_id" "attempt=$attempt"
			exit 0
		fi
		[[ ! -e "$running" ]] || die "cannot retry manager review; running assignment appeared: $running"
		[[ ! -e "$lease" ]] || die "cannot retry manager review; worker lease appeared: $lease"
		[[ -f "$assignment_archive" ]] || die "cannot retry manager review; archived assignment disappeared: $assignment_archive"
		attempt=$((attempt + 1))
		log_event "MANAGER_PROVIDER_RETRY_STARTED task=$task_id thread_id=$thread_id kind=$retry_kind attempt=$attempt retry=$provider_retries"
		trace_event MANAGER_REVIEW_RETRY "task_id=$task_id" "kind=$retry_kind" "attempt=$attempt" "retry=$provider_retries"
		continue
	fi

	if codex_model_requires_narrow_prompt "$current_model" && [[ "$classification" == model_refusal_or_blocked_content ]]; then
		if (( fallback_stage == 0 )); then
			fallback_stage=1; attempt=$((attempt + 1))
			printf '\nRetry scope: review only RESULT_FILE and the bounded assignment; do not inspect unrelated directories.\n' >> "$prompt_file"
			log_event "MANAGER_TERRA_NARROW_RETRY task=$task_id classification=$classification"
			continue
		elif (( fallback_stage == 1 )) && [[ "$MANAGER_FALLBACK_MODEL" != "$current_model" ]]; then
			fallback_stage=2; current_model="$MANAGER_FALLBACK_MODEL"; attempt=$((attempt + 1))
			log_event "MANAGER_MODEL_FALLBACK task=$task_id classification=$classification model=$current_model"
			continue
		fi
	fi

	log_event "MANAGER_REVIEW_FAILED task=$task_id status=$status attempts=$attempt"
	trace_event MANAGER_REVIEW_FAILED "task_id=$task_id" "status=$status" "attempts=$attempt" "json_log=$json_log"
	exit "$status"
done
