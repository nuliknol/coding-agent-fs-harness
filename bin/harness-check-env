#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
require_manager_configuration
require_manager_codex
require_worker_codex
require_oracle_codex

printf 'Environment file: %s\n' "$HARNESS_ENV_FILE"
printf 'Project: %s\n' "$PROJECT"
printf 'Repository: %s\n' "$REPOSITORY"
printf 'Specification: %s\n' "$SPECIFICATION"
printf 'Harness home: %s\n' "$HARNESS_HOME"
printf 'Harness bin: %s\n' "$HARNESS_BIN"
printf 'Harness state root: %s\n' "$HARNESS_ROOT"
printf 'Project tmp dir: %s\n' "$PROJECT_TMP_DIR"
printf 'Manager Codex: %s\n' "$MANAGER_CODEX_BIN"
printf 'Manager Codex home: %s\n' "$MANAGER_CODEX_HOME"
printf 'Manager model: %s (%s)\n' "$MANAGER_MODEL" "$MANAGER_REASONING_EFFORT"
printf 'Manager sandbox: %s\n' "$MANAGER_SANDBOX"
printf 'Worker Codex: %s\n' "$WORKER_CODEX_BIN"
printf 'Worker Codex home: %s\n' "$WORKER_CODEX_HOME"
printf 'Worker model: %s (%s)\n' "$WORKER_MODEL" "$WORKER_REASONING_EFFORT"
printf 'Worker sandbox: %s\n' "$WORKER_SANDBOX"
printf 'Oracle enabled: %s\n' "$ORACLE_ENABLED"
if oracle_enabled; then
	printf 'Oracle Codex: %s\n' "$ORACLE_CODEX_BIN"
	printf 'Oracle Codex home: %s\n' "$ORACLE_CODEX_HOME"
	printf 'Oracle model: %s (%s)\n' "$ORACLE_MODEL" "$ORACLE_REASONING_EFFORT"
	printf 'Oracle sandbox: %s\n' "$ORACLE_SANDBOX"
fi
printf 'Worker heartbeat seconds: %s\n' "$WORKER_HEARTBEAT_SECONDS"
printf 'Poll seconds: %s\n' "$HARNESS_POLL_SECONDS"
printf 'Wait seconds: %s\n' "$HARNESS_WAIT_SECONDS"
printf 'Stale seconds: %s\n' "$HARNESS_STALE_SECONDS"
printf 'Use inotify: %s\n' "$HARNESS_USE_INOTIFY"
if (( HARNESS_MAX_IDENTICAL_BLOCKERS == 0 )); then
	printf 'Deterministic blocker circuit breaker: disabled\n'
else
	printf 'Deterministic blocker circuit breaker: %s identical zero-progress fingerprints\n' "$HARNESS_MAX_IDENTICAL_BLOCKERS"
fi
printf 'Rejected-root worker thread reuse: %s\n' "$([[ "$HARNESS_REUSE_WORKER_THREADS" == 1 ]] && printf enabled || printf disabled)"
if (( HARNESS_WORKER_THREAD_MAX_REJECTIONS == 0 )); then
	printf 'Worker thread rejection rotation: unlimited\n'
else
	printf 'Worker thread rejection rotation: %s retained rejections\n' "$HARNESS_WORKER_THREAD_MAX_REJECTIONS"
fi
if (( HARNESS_CLOSURE_MODE_ENABLED == 1 )); then
	printf 'Bounded closure mode: enabled at %s%% (%s fixes, %s focused-smoke runs)\n' \
		"$HARNESS_CLOSURE_MODE_MIN_PROGRESS" "$HARNESS_CLOSURE_MODE_MAX_FIXES" "$HARNESS_CLOSURE_MODE_MAX_SMOKE_RUNS"
else
	printf 'Bounded closure mode: disabled\n'
fi
printf 'Transient provider retry seconds: %s (retries unlimited)\n' "$HARNESS_PROVIDER_RETRY_SECONDS"
printf 'Quota retry seconds: %s (retries unlimited)\n' "$HARNESS_QUOTA_RETRY_SECONDS"
printf 'Codex wall timeout seconds: %s (0 means unlimited)\n' "$HARNESS_CODEX_WALL_TIMEOUT_SECONDS"
printf 'Codex idle timeout seconds: %s (0 means unlimited)\n' "$HARNESS_CODEX_IDLE_TIMEOUT_SECONDS"
printf 'Task revisions: cumulative progress is persisted; revisions remain automatic unless the circuit breaker is explicitly enabled\n'
