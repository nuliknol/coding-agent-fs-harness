#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
require_manager_configuration
require_manager_codex
trace_init manager_bootstrap
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
write_manager_snapshot

project_path="$(project_dir)"
last_message="$project_path/logs/manager-bootstrap-last-message.md"
prompt_file="$project_path/control/manager-bootstrap.prompt.md"
development_policy_file="$REPOSITORY/design/development-policy.txt"
[[ -f "$development_policy_file" ]] || development_policy_file=""
cat > "$prompt_file.tmp.$$" <<PROMPT
Read $HARNESS_HOME/prompts/manager-agent-event-driven.md and follow it.

HARNESS_BIN=$HARNESS_BIN
ENV_FILE=$HARNESS_ENV_FILE
PROJECT=$PROJECT
PROJECT_TMP_DIR=$PROJECT_TMP_DIR
SPECIFICATION=$SPECIFICATION
REPOSITORY=$REPOSITORY
DEVELOPMENT_POLICY_FILE=$development_policy_file

This is the bootstrap turn. Read DEVELOPMENT_POLICY_FILE when present and inspect the complete specification. First write a tab-separated project plan under PROJECT_TMP_DIR with one immutable line per specification phase or acceptance gate: ITEM_ID<TAB>TITLE. Include the full execution stack, not merely the first task. Register it with manager-init-project-plan. Then inspect the repository, write one bounded initial assignment under PROJECT_TMP_DIR, and publish it with manager-publish-task including the corresponding PROJECT_PLAN_ITEM_ID. Terminate after exactly one task is published. Every harness command must receive ENV_FILE as its first argument. Do not wait for the worker and do not run any polling command.
PROMPT
if codex_model_requires_narrow_prompt "$MANAGER_MODEL"; then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Context: authorized local development in my own repository. Task type: benign software engineering. Do not perform offensive security, credential extraction, vulnerability exploitation, malware behavior, unauthorized access, network scanning, or bypassing security controls. Use only the listed local project files needed for the requested implementation: SPECIFICATION and files explicitly necessary to create one bounded initial assignment.
PROMPT
fi
chmod 600 "$prompt_file.tmp.$$"
mv "$prompt_file.tmp.$$" "$prompt_file"

extract_thread_id()
{
	local log_file="$1"
	if command -v jq >/dev/null 2>&1; then
		jq -r 'select(.type == "thread.started") | .thread_id' "$log_file" | head -n 1
	else
		sed -n 's/.*"type"[[:space:]]*:[[:space:]]*"thread.started".*"thread_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$log_file" | head -n 1
	fi
}

bootstrap_task_published()
{
	compgen -G "$project_path/tasks/$PROJECT-task-*.ready.md" >/dev/null
}

attempt=1
capacity_retries=0
resume_thread_id=""
status=0
json_log=""
stderr_log=""
classification=""
fallback_stage=0
current_model="$MANAGER_MODEL"

while true; do
	stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
	attempt_label="$(printf '%03d' "$attempt")"
	json_log="$project_path/logs/manager-bootstrap-$stamp-attempt-$attempt_label.jsonl"
	stderr_log="$project_path/logs/manager-bootstrap-$stamp-attempt-$attempt_label.stderr.log"
	attempt_last_message="$project_path/logs/manager-bootstrap-$stamp-attempt-$attempt_label.md"

	log_event "MANAGER_BOOTSTRAP_STARTED attempt=$attempt"
	trace_event MANAGER_BOOTSTRAP_ATTEMPT "attempt=$attempt" "resume_thread_id=${resume_thread_id:-}" "json_log=$json_log" "last_message=$attempt_last_message"
	set +e
	if [[ -n "$resume_thread_id" ]]; then
		trace_event CODEX_EXEC_START "role=manager_bootstrap" "attempt=$attempt" "mode=resume" "thread_id=$resume_thread_id" "json_log=$json_log" "last_message=$attempt_last_message" "model=$MANAGER_MODEL"
		"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" manager_bootstrap "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$attempt_last_message" resume "$resume_thread_id"
	else
		trace_event CODEX_EXEC_START "role=manager_bootstrap" "attempt=$attempt" "mode=new" "json_log=$json_log" "last_message=$attempt_last_message" "model=$MANAGER_MODEL"
		"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" manager_bootstrap "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$attempt_last_message"
	fi
	status=$?
	set -e
	classification="$(kv_file_value "${json_log%.jsonl}.classification" classification 2>/dev/null || true)"
	trace_event CODEX_EXEC_END "role=manager_bootstrap" "attempt=$attempt" "status=$status" "json_log=$json_log" "last_message=$attempt_last_message"

	thread_id="$(extract_thread_id "$json_log")"
	if [[ -n "$thread_id" && "$thread_id" != "null" ]]; then
		resume_thread_id="$thread_id"
	fi

	if (( status == 0 )); then
		project_plan_exists || die "manager bootstrap exited without initializing the project plan"
		bootstrap_task_published || die "manager bootstrap exited without publishing the first task"
		[[ -n "$resume_thread_id" ]] || die "could not extract Codex thread id from $json_log"
		cp -f "$attempt_last_message" "$last_message" 2>/dev/null || true
		"$HARNESS_BIN/manager-register-thread" "$HARNESS_ENV_FILE" "$resume_thread_id" >/dev/null
		log_event "MANAGER_BOOTSTRAPPED thread_id=$resume_thread_id attempts=$attempt"
		trace_event MANAGER_BOOTSTRAP_COMMITTED "thread_id=$resume_thread_id" "attempts=$attempt" "status=$status"
		printf 'Manager bootstrap completed and exited.\n'
		printf 'Thread ID: %s\n' "$resume_thread_id"
		exit 0
	fi

	# If the manager published the first task immediately before the API stream
	# failed, registering the captured thread is safer than replaying bootstrap
	# and potentially publishing a duplicate first task.
	if project_plan_exists && bootstrap_task_published; then
		[[ -n "$resume_thread_id" ]] || die "manager published an initial task but no thread id could be recovered from $json_log"
		cp -f "$attempt_last_message" "$last_message" 2>/dev/null || true
		"$HARNESS_BIN/manager-register-thread" "$HARNESS_ENV_FILE" "$resume_thread_id" >/dev/null
		log_event "MANAGER_BOOTSTRAPPED thread_id=$resume_thread_id attempts=$attempt outcome=task_published_before_process_failure status=$status"
		trace_event MANAGER_BOOTSTRAP_RECOVERED "thread_id=$resume_thread_id" "attempts=$attempt" "status=$status"
		printf 'Manager bootstrap task was published before the Codex process failed; recovered thread %s.\n' "$resume_thread_id"
		exit 0
	fi

	if codex_model_requires_narrow_prompt "$current_model" && [[ "$classification" != success ]]; then
		if (( fallback_stage == 0 )); then
			fallback_stage=1; attempt=$((attempt + 1))
			printf '\nRetry scope: create one bounded initial assignment only; do not inspect unrelated directories.\n' >> "$prompt_file"
			log_event "MANAGER_TERRA_NARROW_RETRY classification=$classification"
			continue
		elif (( fallback_stage == 1 )) && [[ "$MANAGER_FALLBACK_MODEL" != "$current_model" ]]; then
			fallback_stage=2; current_model="$MANAGER_FALLBACK_MODEL"; attempt=$((attempt + 1))
			log_event "MANAGER_MODEL_FALLBACK classification=$classification model=$current_model"
			continue
		fi
	fi

	if codex_log_has_capacity_error "$json_log" && capacity_retry_allowed "$capacity_retries"; then
		capacity_retries=$((capacity_retries + 1))
		log_event "MANAGER_BOOTSTRAP_CAPACITY_RETRY_SCHEDULED attempt=$attempt retry=$capacity_retries delay_seconds=$HARNESS_CAPACITY_RETRY_SECONDS"
		printf 'Manager model is at capacity during bootstrap; retrying in %s seconds.\n' "$HARNESS_CAPACITY_RETRY_SECONDS" >&2
		sleep "$HARNESS_CAPACITY_RETRY_SECONDS"
		attempt=$((attempt + 1))
		log_event "MANAGER_BOOTSTRAP_CAPACITY_RETRY_STARTED attempt=$attempt retry=$capacity_retries"
		trace_event MANAGER_BOOTSTRAP_RETRY "attempt=$attempt" "retry=$capacity_retries"
		continue
	fi

	die "Codex manager bootstrap failed with exit status $status; see $json_log"
done
