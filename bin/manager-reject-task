#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID REVIEW_NOTE_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 3 ]] || usage
load_harness_env "$1"
task_id="$2"
note_file="$3"

ensure_project
validate_task_id "$task_id"
[[ -f "$note_file" ]] || die "review note file does not exist: $note_file"
acquire_project_lock

dir="$(project_dir)"
base="$(task_base "$task_id")"
result="$dir/results/$base.result.md"
result_archive="$dir/archive/$base.rejected-result.md"
rejected="$dir/archive/$base.rejected.md"
[[ -f "$result" ]] || die "result does not exist: $task_id"
[[ ! -e "$rejected" ]] || die "task already rejected: $task_id"

mv "$result" "$result_archive"
tmp="$rejected.tmp.$$"
{
	printf '# Rejected Task\n\n'
	printf 'Project: %s\n\n' "$PROJECT"
	printf 'Task-ID: %s\n\n' "$task_id"
	printf 'Environment-File: %s\n\n' "$HARNESS_ENV_FILE"
	printf 'Rejected-At: %s\n\n' "$(timestamp_utc)"
	printf '## Review notes\n\n'
	cat "$note_file"
	printf '\n'
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$rejected"
log_event "TASK_REJECTED task=$task_id"
printf '%s\n' "$rejected"
