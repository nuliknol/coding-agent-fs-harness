#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID REVIEW_NOTE_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 3 ]] || usage
load_harness_env "$1"
task_id="$2"
note_file="$3"

ensure_project
trace_init manager_reject_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
[[ -f "$note_file" ]] || die "review note file does not exist: $note_file"
grep -Eq '^Improvement-Percent: (100|[1-9]?[0-9])%$' "$note_file" || die 'review note must contain Improvement-Percent: N% (0 through 100)'
acquire_project_lock

dir="$(project_dir)"
base="$(task_base "$task_id")"
root="$(task_root_id "$task_id")"
initialize_task_progress "$task_id" "$dir/archive/$base.assignment.md"
current_progress="$(task_progress_percent "$root")"
improvement_percent="$(review_percent "$note_file" Improvement-Percent)"
progress_percent="$(review_percent "$note_file" Progress-Percent)"
if [[ -z "$progress_percent" ]]; then
	# Compatibility for an already-running pre-refactor manager turn. New turns
	# must report cumulative progress explicitly.
	progress_percent=$((current_progress + improvement_percent))
	(( progress_percent < 100 )) || progress_percent=99
	log_event "TASK_PROGRESS_MIGRATED task=$task_id inferred_progress=$progress_percent"
fi
validate_percent "$progress_percent" 'Progress-Percent'
(( progress_percent >= current_progress )) || die "Progress-Percent cannot decrease from $current_progress% to $progress_percent%"
(( progress_percent < 100 )) || die 'a rejected task must have Progress-Percent below 100%'

# Circuit-break a deterministic blocker rather than paying for unbounded
# no-op revisions.  The manager supplies the stable output hash/fingerprint
# only when the same unmet gate is being retried; different failures continue
# through normal bounded review.
blocking_fingerprint="$(awk -F': ' '$1 == "Blocking-Fingerprint" {print $2; exit}' "$note_file")"
if [[ "$improvement_percent" == 0 ]]; then
	[[ "$blocking_fingerprint" =~ ^sha256:[0-9a-fA-F]{64}$ ]] ||
		die 'zero-improvement rejection requires Blocking-Fingerprint: sha256:<64-hex-digest>'
	matching_rejections=0
	shopt -s nullglob
	for prior_rejection in "$dir/archive/$PROJECT-task-$root.rejected.md" \
		"$dir/archive/$PROJECT-task-$root-revision-"*.rejected.md; do
		[[ -f "$prior_rejection" ]] || continue
		if grep -Fqx 'Improvement-Percent: 0%' "$prior_rejection" &&
			grep -Fqx "Blocking-Fingerprint: $blocking_fingerprint" "$prior_rejection"; then
			matching_rejections=$((matching_rejections + 1))
		fi
	done
	if (( HARNESS_MAX_IDENTICAL_BLOCKERS > 0 && matching_rejections + 1 >= HARNESS_MAX_IDENTICAL_BLOCKERS )); then
		retain_worker_thread_for_rejection "$task_id"
		log_event "TASK_CIRCUIT_BREAKER task=$task_id root=$root fingerprint=$blocking_fingerprint prior_matches=$matching_rejections limit=$HARNESS_MAX_IDENTICAL_BLOCKERS"
		"$HARNESS_BIN/manager-block-task" "$HARNESS_ENV_FILE" "$task_id" "$note_file" "identical zero-progress blocker fingerprint $blocking_fingerprint reached limit $HARNESS_MAX_IDENTICAL_BLOCKERS" --lock-held
		exit 0
	fi
fi
result="$dir/results/$base.result.md"
result_archive="$dir/archive/$base.rejected-result.md"
rejected="$dir/archive/$base.rejected.md"
stale_result_archive="$dir/archive/$base.rejected-stale-result.md"

archive_lingering_result()
{
	if [[ ! -f "$result" ]]; then
		return 0
	fi
	if [[ -f "$result_archive" ]]; then
		mv "$result" "$stale_result_archive"
		log_event "TASK_REJECTED_STALE_RESULT_ARCHIVED task=$task_id file=$stale_result_archive"
	else
		mv "$result" "$result_archive"
		log_event "TASK_REJECTED_RESULT_RECOVERED task=$task_id file=$result_archive"
	fi
}

if [[ -f "$rejected" ]]; then
	archive_lingering_result
	retain_worker_thread_for_rejection "$task_id"
	trace_event TASK_REJECT_IDEMPOTENT "task_id=$task_id" "rejected_file=$rejected"
	printf '%s\n' "$rejected"
	exit 0
fi

[[ -f "$result" ]] || die "result does not exist: $task_id"

mv "$result" "$result_archive"
tmp="$rejected.tmp.$$"
{
	printf '# Rejected Task\n\n'
	printf 'Project: %s\n\n' "$PROJECT"
	printf 'Task-ID: %s\n\n' "$task_id"
	printf 'Environment-File: %s\n\n' "$HARNESS_ENV_FILE"
	printf 'Rejected-At: %s\n\n' "$(timestamp_utc)"
	printf '## Review notes\n\n'
	cat "$note_file"
	printf '\n'
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$rejected"
update_task_progress "$task_id" "$progress_percent" "$improvement_percent" REJECT "$note_file"
retain_worker_thread_for_rejection "$task_id"
log_event "TASK_REJECTED task=$task_id"
trace_event TASK_REJECTED "task_id=$task_id" "rejected_file=$rejected" "result_archive=$result_archive" "note_file=$note_file"
printf '%s\n' "$rejected"
