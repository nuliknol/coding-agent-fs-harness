#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	printf 'Remove a project-wide Oracle approval block after the required human decision.\n' >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
acquire_project_lock

block="$(project_block_file)"
[[ -f "$block" ]] || die 'project is not blocked'
rm -f "$block"
log_event 'PROJECT_UNBLOCKED source=human-oracle-approval'
printf 'Project %s is unblocked. Restart the harness to continue.\n' "$PROJECT"
