#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
require_manager_configuration
require_manager_codex
trace_init manager_plan_next_task
trace_script_start "$@"
write_manager_snapshot

project_path="$(project_dir)"
plan_running="$project_path/control/manager-plan.running"
cleanup()
{
	local status="$?"
	rm -f "$plan_running"
	trace_script_exit "$status"
}
trap cleanup EXIT
{
	printf 'pid=%s\n' "$$"
	printf 'started_at=%s\n' "$(timestamp_utc)"
	printf 'env_file=%s\n' "$HARNESS_ENV_FILE"
} > "$plan_running.tmp.$$"
chmod 600 "$plan_running.tmp.$$"
mv "$plan_running.tmp.$$" "$plan_running"
thread_file="$project_path/control/manager.thread"
[[ -f "$thread_file" ]] || die 'manager thread is not registered; run manager-bootstrap'
project_plan_exists || die 'project plan is missing'
project_plan_all_complete && die 'project plan is already complete'
thread_id="$(kv_file_value "$thread_file" thread_id)"
plan_definition="$(project_plan_definition_file)"
plan_state="$(project_plan_state_file)"
development_policy_file="$REPOSITORY/design/development-policy.txt"
[[ -f "$development_policy_file" ]] || development_policy_file=""
prompt_file="$project_path/control/manager-plan-next-task.prompt.md"
active_item_before="$(awk -F '\t' '!/^#/ && $2 == "ACTIVE" {print $1; exit}' "$plan_state")"
active_root_before="$(awk -F '\t' '!/^#/ && $2 == "ACTIVE" {print $3; exit}' "$plan_state")"
active_progress_file=""
active_criteria_file=""
active_criteria_definition_file=""
active_first_unmet_criterion=""
if [[ -n "$active_root_before" && "$active_root_before" != '-' ]]; then
	active_progress_file="$(task_progress_file "$active_root_before")"
	active_criteria_file="$(task_criterion_ledger_file "$active_root_before")"
	active_criteria_definition_file="$(task_criteria_definition_file "$active_root_before")"
	active_first_unmet_criterion="$(task_first_unmet_criterion "$active_root_before" 2>/dev/null || true)"
fi

cat > "$prompt_file.tmp.$$" <<PROMPT
The previous root task is resolved, or an ACTIVE root was explicitly resumed after replanning; the project has no active task process and its specification is not complete.

ENV_FILE=$HARNESS_ENV_FILE
PROJECT=$PROJECT
PROJECT_TMP_DIR=$PROJECT_TMP_DIR
PROJECT_PLAN_FILE=$plan_definition
PROJECT_PLAN_STATE_FILE=$plan_state
PROJECT_PROGRESS_PERCENT=$(project_plan_progress_percent)
DEVELOPMENT_POLICY_FILE=$development_policy_file
SPECIFICATION=$SPECIFICATION
REPOSITORY=$REPOSITORY
HARNESS_BIN=$HARNESS_BIN
ACTIVE_PLAN_ITEM=$active_item_before
ACTIVE_TASK_ROOT=$active_root_before
ACTIVE_PROGRESS_FILE=$active_progress_file
ACTIVE_CRITERIA_FILE=$active_criteria_file
ACTIVE_CRITERIA_DEFINITION_FILE=$active_criteria_definition_file
ACTIVE_FIRST_UNMET_CRITERION=$active_first_unmet_criterion

Read $HARNESS_HOME/prompts/manager-agent-event-driven.md and follow it. Read DEVELOPMENT_POLICY_FILE when present, then read PROJECT_PLAN_FILE and PROJECT_PLAN_STATE_FILE completely. If ACTIVE_TASK_ROOT is set, also read ACTIVE_PROGRESS_FILE, ACTIVE_CRITERIA_FILE, and ACTIVE_CRITERIA_DEFINITION_FILE when present, then publish one newly bounded continuation of that same root with Target-Criterion equal to ACTIVE_FIRST_UNMET_CRITERION. Otherwise select the first PENDING item in specification order and publish a new root whose independently verifiable criteria are declared with stable Root-Criterion lines. Inspect the specification and actual repository state, write exactly one bounded task under PROJECT_TMP_DIR, and publish it with manager-publish-task including its PROJECT_PLAN_ITEM_ID. Preserve completed implementation and begin at the first unmet criterion. Then terminate immediately. Do not wait, sleep, poll, watch the filesystem, or repeat completed plan items.
PROMPT
if codex_model_requires_narrow_prompt "$MANAGER_MODEL"; then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Context: authorized local development in my own repository. Task type: benign software engineering. Do not perform offensive security, credential extraction, vulnerability exploitation, malware behavior, unauthorized access, network scanning, or bypassing security controls. Use only the listed local project files needed to publish the next bounded implementation task.
PROMPT
fi
chmod 600 "$prompt_file.tmp.$$"
mv "$prompt_file.tmp.$$" "$prompt_file"

task_published()
{
	compgen -G "$project_path/tasks/$PROJECT-task-*.ready.md" >/dev/null ||
		compgen -G "$project_path/running/$PROJECT-task-*.running.md" >/dev/null ||
		compgen -G "$project_path/results/$PROJECT-task-*.result.md" >/dev/null ||
		{ [[ -z "$active_item_before" ]] && awk -F '\t' '!/^#/ && $2 == "ACTIVE" {found=1} END {exit found ? 0 : 1}' "$plan_state"; }
}

attempt=1
provider_retries=0
quota_waits=0
fallback_stage=0
current_model="$MANAGER_MODEL"
while true; do
	stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
	attempt_label="$(printf '%03d' "$attempt")"
	json_log="$project_path/logs/manager-plan-$stamp-attempt-$attempt_label.jsonl"
	stderr_log="$project_path/logs/manager-plan-$stamp-attempt-$attempt_label.stderr.log"
	last_message="$project_path/logs/manager-plan-$stamp-attempt-$attempt_label.md"
	log_event "MANAGER_PLAN_STARTED attempt=$attempt project_progress=$(project_plan_progress_percent)"
	trace_event MANAGER_PLAN_ATTEMPT "attempt=$attempt" "thread_id=$thread_id" "json_log=$json_log"
	set +e
	"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" manager_plan "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$last_message" resume "$thread_id"
	status=$?
	set -e
	classification="$(kv_file_value "${json_log%.jsonl}.classification" classification 2>/dev/null || true)"
	if task_published; then
		log_event "MANAGER_PLAN_COMMITTED attempt=$attempt"
		trace_event MANAGER_PLAN_COMMITTED "attempt=$attempt" "status=$status"
		printf 'Manager published the next project task and exited.\n'
		exit 0
	fi
	if (( status == 0 )); then
		log_event "MANAGER_PLAN_LEFT_PENDING attempt=$attempt"
		exit 3
	fi
	retry_kind="$(codex_provider_retry_kind "$classification" 2>/dev/null || true)"
	if [[ -n "$retry_kind" ]]; then
		retry_delay="$(codex_provider_retry_delay "$classification")"
		provider_retries=$((provider_retries + 1))
		[[ "$retry_kind" != quota ]] || quota_waits=$((quota_waits + 1))
		log_event "MANAGER_PLAN_PROVIDER_WAIT kind=$retry_kind attempt=$attempt retry=$provider_retries delay_seconds=$retry_delay classification=$classification"
		if [[ "$retry_kind" == quota ]]; then
			printf 'Manager planning has no provider quota; project plan state is preserved. Checking again in %s seconds (quota wait %s).\n' "$retry_delay" "$quota_waits" >&2
		else
			printf 'Manager planning hit a transient provider/network failure; retrying in %s seconds.\n' "$retry_delay" >&2
		fi
		sleep "$retry_delay"
		attempt=$((attempt + 1))
		log_event "MANAGER_PLAN_PROVIDER_RETRY_STARTED kind=$retry_kind attempt=$attempt retry=$provider_retries"
		continue
	fi

	if codex_model_requires_narrow_prompt "$current_model" && [[ "$classification" == model_refusal_or_blocked_content ]]; then
		if (( fallback_stage == 0 )); then
			fallback_stage=1
			attempt=$((attempt + 1))
			printf '\nRetry scope: publish exactly one task for the first unfinished project plan item.\n' >> "$prompt_file"
			continue
		elif (( fallback_stage == 1 )) && [[ "$MANAGER_FALLBACK_MODEL" != "$current_model" ]]; then
			fallback_stage=2
			current_model="$MANAGER_FALLBACK_MODEL"
			attempt=$((attempt + 1))
			continue
		fi
	fi
	die "Codex manager planning turn failed with exit status $status; see $json_log"
done
