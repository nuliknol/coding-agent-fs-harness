#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ROOT\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 2 ]] || usage
load_harness_env "$1"
root="$2"
ensure_project
validate_task_id "$root"
[[ "$(task_root_id "$root")" == "$root" ]] || die 'TASK_ROOT must not be a revision ID'
acquire_project_lock

block="$(task_root_block_file "$root")"
replan="$(task_root_replan_file "$root")"
human="$(task_root_human_file "$root")"
[[ -f "$block" || -f "$replan" || -f "$human" ]] ||
	die "task root is not blocked, awaiting replanning, or awaiting human intervention: $root"
had_block=0
had_replan=0
had_human=0
[[ ! -f "$block" ]] || had_block=1
[[ ! -f "$replan" ]] || had_replan=1
[[ ! -f "$human" ]] || had_human=1
if (( had_replan == 1 || had_human == 1 )); then
	record_root_convergence_baseline "$root"
	record_root_replan_baseline "$root"
fi
rm -f "$block" "$replan" "$human"
log_event "TASK_ROOT_UNBLOCKED root=$root cleared_block=$had_block cleared_replan=$had_replan cleared_human=$had_human"
printf '%s\n' "$root"
