#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID [REVIEW_NOTE_FILE] [--complete-project]\n' "${0##*/}" >&2
	exit 2
}

[[ $# -ge 2 && $# -le 4 ]] || usage
load_harness_env "$1"
task_id="$2"
note_file="${3:-}"
complete_flag="${4:-}"

if [[ "$note_file" == '--complete-project' && -z "$complete_flag" ]]; then
	complete_flag="$note_file"
	note_file=""
fi

ensure_project
trace_init manager_accept_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
[[ -z "$note_file" || -f "$note_file" ]] || die "review note file does not exist: $note_file"
[[ -z "$complete_flag" || "$complete_flag" == '--complete-project' ]] || usage
acquire_project_lock

dir="$(project_dir)"
base="$(task_base "$task_id")"
result="$dir/results/$base.result.md"
result_archive="$dir/archive/$base.result.md"
accepted="$dir/archive/$base.accepted.md"
stale_result_archive="$dir/archive/$base.accepted-stale-result.md"

archive_lingering_result()
{
	if [[ ! -f "$result" ]]; then
		return 0
	fi
	if [[ -f "$result_archive" ]]; then
		mv "$result" "$stale_result_archive"
		log_event "TASK_ACCEPTED_STALE_RESULT_ARCHIVED task=$task_id file=$stale_result_archive"
	else
		mv "$result" "$result_archive"
		log_event "TASK_ACCEPTED_RESULT_RECOVERED task=$task_id file=$result_archive"
	fi
}

if [[ -f "$accepted" ]]; then
	archive_lingering_result
	trace_event TASK_ACCEPT_IDEMPOTENT "task_id=$task_id" "accepted_file=$accepted"
	printf '%s\n' "$accepted"
	exit 0
fi

[[ -f "$result" ]] || die "result does not exist: $task_id"
mv "$result" "$result_archive"

tmp="$accepted.tmp.$$"
{
	printf '# Accepted Task\n\n'
	printf 'Project: %s\n\n' "$PROJECT"
	printf 'Task-ID: %s\n\n' "$task_id"
	printf 'Environment-File: %s\n\n' "$HARNESS_ENV_FILE"
	printf 'Accepted-At: %s\n' "$(timestamp_utc)"
	if [[ -n "$note_file" ]]; then
		printf '\n## Review notes\n\n'
		cat "$note_file"
		printf '\n'
	fi
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$accepted"

rm -f "$dir/control/$base.lease" "$dir/control/$base.abort.md" "$dir/control/$base.worker-triggered" "$dir/control/$base.worker-failed.md" "$dir/control/$base.worker-supervisor-failed.md"
log_event "TASK_ACCEPTED task=$task_id"
trace_event TASK_ACCEPTED "task_id=$task_id" "accepted_file=$accepted" "result_archive=$result_archive" "note_file=${note_file:-}"
if [[ "$complete_flag" == '--complete-project' ]]; then
	mark_project_complete "$task_id" "$note_file"
fi
printf '%s\n' "$accepted"
