#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID [REVIEW_NOTE_FILE] [--complete-project]\n' "${0##*/}" >&2
	exit 2
}

[[ $# -ge 2 && $# -le 4 ]] || usage
load_harness_env "$1"
task_id="$2"
note_file="${3:-}"
complete_flag="${4:-}"

if [[ "$note_file" == '--complete-project' && -z "$complete_flag" ]]; then
	complete_flag="$note_file"
	note_file=""
fi

ensure_project
trace_init manager_accept_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
[[ -z "$note_file" || -f "$note_file" ]] || die "review note file does not exist: $note_file"
[[ -z "$complete_flag" || "$complete_flag" == '--complete-project' ]] || usage
acquire_project_lock

dir="$(project_dir)"
base="$(task_base "$task_id")"
result="$dir/results/$base.result.md"
result_archive="$dir/archive/$base.result.md"
accepted="$dir/archive/$base.accepted.md"
stale_result_archive="$dir/archive/$base.accepted-stale-result.md"
assignment_archive="$dir/archive/$base.assignment.md"
running="$dir/running/$base.running.md"
lease="$dir/control/$base.lease"

require_line()
{
	local file="$1"
	local line="$2"
	grep -Fqx -- "$line" "$file" || die "required review evidence is missing: $line"
}

require_heading()
{
	local file="$1"
	local heading="$2"
	grep -Fqx -- "$heading" "$file" || die "required review section is missing: $heading"
}

require_pass_evidence()
{
	local file="$1"
	local heading="$2"
	awk -v heading="$heading" '
		$0 == heading { in_section = 1; next }
		in_section && /^## / { exit }
		in_section && /^- \[PASS\] .+ — .+/ { found = 1 }
		END { exit found ? 0 : 1 }
	' "$file" || die "required PASS evidence is missing from: $heading"
}

validate_worker_result()
{
	local file="$1"
	require_line "$file" "Task-ID: $task_id"
	require_line "$file" 'Status: COMPLETED'
	require_heading "$file" '## Summary'
	require_heading "$file" '## Modified files'
	require_heading "$file" '## Implemented behavior'
	require_heading "$file" '## Validation performed'
	require_heading "$file" '## Deviations from assignment'
	require_heading "$file" '## Remaining concerns'
	require_heading "$file" '## Worker assessment'
}

validate_acceptance_evidence()
{
	local file="$1"
	[[ -n "$file" ]] || die 'acceptance requires a manager review record'
	require_heading "$file" '# Manager Review Record'
	require_line "$file" "Task-ID: $task_id"
	require_line "$file" 'Decision: ACCEPT'
	require_heading "$file" '## Specification comparison'
	require_heading "$file" '## Acceptance-criteria verification'
	require_heading "$file" '## Feature verification'
	require_heading "$file" '## Validation executed'
	require_heading "$file" '## Scope and regression review'
	require_heading "$file" '## Conclusion'
	require_pass_evidence "$file" '## Acceptance-criteria verification'
	require_pass_evidence "$file" '## Feature verification'
	require_pass_evidence "$file" '## Validation executed'
}

archive_lingering_result()
{
	if [[ ! -f "$result" ]]; then
		return 0
	fi
	if [[ -f "$result_archive" ]]; then
		mv "$result" "$stale_result_archive"
		log_event "TASK_ACCEPTED_STALE_RESULT_ARCHIVED task=$task_id file=$stale_result_archive"
	else
		mv "$result" "$result_archive"
		log_event "TASK_ACCEPTED_RESULT_RECOVERED task=$task_id file=$result_archive"
	fi
}

if [[ -f "$accepted" ]]; then
	archive_lingering_result
	clear_worker_thread_for_root "$task_id" accepted
	trace_event TASK_ACCEPT_IDEMPOTENT "task_id=$task_id" "accepted_file=$accepted"
	printf '%s\n' "$accepted"
	exit 0
fi

[[ -f "$result" ]] || die "result does not exist: $task_id"
[[ -f "$assignment_archive" ]] || die "archived assignment is missing: $task_id"
[[ ! -e "$running" ]] || die "task is still running: $task_id"
[[ ! -e "$lease" ]] || die "worker lease still exists: $task_id"
validate_worker_result "$result"
validate_acceptance_evidence "$note_file"
initialize_task_progress "$task_id" "$assignment_archive"
current_progress="$(task_progress_percent "$task_id")"
accept_improvement=$((100 - current_progress))
root="$(task_root_id "$task_id")"
root_assignment="$(task_root_assignment_file "$root")"
criterion_ledger="$(task_criterion_ledger_file "$root")"
mapfile -t declared_criteria < <(task_root_leaf_criteria "$task_id")
mapfile -t accepted_criteria < <(awk -F': ' '$1 == "Verified-Criterion" {print $2}' "$note_file")
if (( ${#declared_criteria[@]} > 0 )); then
	require_line "$note_file" 'Progress-Percent: 100%'
	declare -A declared_criterion_ids=()
	for criterion in "${declared_criteria[@]}"; do
		[[ "$criterion" =~ ^[A-Za-z0-9][A-Za-z0-9._:-]*$ ]] ||
			die "invalid Root-Criterion identifier in immutable assignment: $criterion"
		[[ -z "${declared_criterion_ids[$criterion]:-}" ]] ||
			die "duplicate Root-Criterion identifier in immutable assignment: $criterion"
		declared_criterion_ids[$criterion]=1
	done
	(( ${#accepted_criteria[@]} == 1 )) ||
		die 'final acceptance must complete exactly one independently bounded remaining leaf criterion'
	first_unmet="$(task_first_unmet_criterion "$task_id" 2>/dev/null || true)"
	[[ -n "$first_unmet" ]] ||
		die 'all declared leaf criteria are already passed; reconcile the root instead of accepting another result'
	for criterion in "${accepted_criteria[@]}"; do
		[[ "$criterion" =~ ^[A-Za-z0-9][A-Za-z0-9._:-]*$ ]] ||
			die "invalid Verified-Criterion identifier: $criterion"
		[[ -n "${declared_criterion_ids[$criterion]:-}" ]] ||
			die "Verified-Criterion is not an active leaf in the immutable root criterion inventory: $criterion"
		! task_criterion_is_passed "$root" "$criterion" ||
			die "root criterion is already checkpointed: $criterion"
	done
	[[ "${accepted_criteria[0]}" == "$first_unmet" ]] ||
		die "final acceptance must complete the first unmet criterion: $first_unmet"
	for criterion in "${declared_criteria[@]}"; do
		[[ "$criterion" == "$first_unmet" ]] && continue
		task_criterion_is_passed "$root" "$criterion" ||
			die "cannot accept root; declared leaf criterion lacks verified evidence: $criterion"
	done
fi

project_plan_exists || die 'cannot accept a task without a persistent project plan'
plan_item_id="$(project_plan_item_for_root "$(task_root_id "$task_id")")"
[[ -n "$plan_item_id" ]] || die "task is not assigned to the project plan: $task_id"
if [[ "$complete_flag" == '--complete-project' ]]; then
	unfinished_other_items="$(awk -F '\t' -v item="$plan_item_id" '!/^#/ && $1 != item && $2 != "COMPLETE" {count++} END {print count + 0}' "$(project_plan_state_file)")"
	(( unfinished_other_items == 0 )) || die "refusing --complete-project; $unfinished_other_items other project plan item(s) remain unfinished"
fi
mv "$result" "$result_archive"

tmp="$accepted.tmp.$$"
{
	printf '# Accepted Task\n\n'
	printf 'Project: %s\n\n' "$PROJECT"
	printf 'Task-ID: %s\n\n' "$task_id"
	printf 'Environment-File: %s\n\n' "$HARNESS_ENV_FILE"
	printf 'Accepted-At: %s\n' "$(timestamp_utc)"
	if [[ -n "$note_file" ]]; then
		printf '\n## Review notes\n\n'
		cat "$note_file"
		printf '\n'
	fi
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$accepted"
if (( ${#accepted_criteria[@]} > 0 )); then
	if [[ ! -f "$criterion_ledger" ]]; then
		printf 'item_id\tstate\tverified_by\tevidence_sha256\tupdated_at\n' > "$criterion_ledger"
		chmod 600 "$criterion_ledger"
	fi
	review_sha="$(sha256sum "$note_file" | awk '{print $1}')"
	for criterion in "${accepted_criteria[@]}"; do
		printf '%s\tPASSED\t%s\t%s\t%s\n' "$criterion" "$task_id" "$review_sha" "$(timestamp_utc)" >> "$criterion_ledger"
	done
fi
update_task_progress "$task_id" 100 "$accept_improvement" ACCEPT "$note_file"
complete_project_plan_item_for_task "$task_id"
clear_worker_thread_for_root "$task_id" accepted

rm -f "$dir/control/$base.lease" "$dir/control/$base.abort.md" "$dir/control/$base.worker-triggered" "$dir/control/$base.worker-failed.md" "$dir/control/$base.worker-supervisor-failed.md"
log_event "TASK_ACCEPTED task=$task_id"
trace_event TASK_ACCEPTED "task_id=$task_id" "accepted_file=$accepted" "result_archive=$result_archive" "note_file=${note_file:-}"
if project_plan_all_complete; then
	if oracle_enabled; then
		mark_project_awaiting_oracle "$task_id" "$note_file"
	else
		mark_project_complete "$task_id" "$note_file"
	fi
fi
printf '%s\n' "$accepted"
