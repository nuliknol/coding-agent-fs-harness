#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project

dir="$(project_dir)"
if project_plan_exists; then
	printf -v project_progress_line 'Project progress: %s%% (%s/%s plan items complete)' \
		"$(project_plan_progress_percent)" "$(project_plan_complete_count)" "$(project_plan_total_count)"
else
	project_progress_line='Project progress: unavailable (project plan is missing)'
fi

printf 'Environment file: %s\n' "$HARNESS_ENV_FILE"
printf 'Project: %s\n' "$PROJECT"
printf 'Repository: %s\n' "$REPOSITORY"
printf 'Harness root: %s\n' "$HARNESS_ROOT"
manager_supervisor='stopped'
worker_supervisor='stopped'
if [[ -f "$dir/control/supervisor.pid" ]]; then
	pid="$(cat "$dir/control/supervisor.pid")"
	if kill -0 "$pid" 2>/dev/null; then manager_supervisor="running (PID $pid)"; fi
fi
if [[ -f "$dir/control/worker-supervisor.pid" ]]; then
	pid="$(cat "$dir/control/worker-supervisor.pid")"
	if kill -0 "$pid" 2>/dev/null; then worker_supervisor="running (PID $pid)"; fi
fi
printf 'Manager supervisor: %s\n' "$manager_supervisor"
printf 'Worker supervisor: %s\n' "$worker_supervisor"
if oracle_enabled; then
	if [[ -f "$(project_block_file)" ]]; then
		printf 'Oracle audit: BLOCKED (%s)\n' "$(project_block_file)"
	elif [[ -f "$(project_oracle_pending_file)" ]]; then
		printf 'Oracle audit: PENDING\n'
	else
		printf 'Oracle audit: enabled\n'
	fi
fi
if project_plan_exists; then
	printf '\n%-24s %-12s %-16s %s\n' 'PLAN ITEM' 'STATE' 'TASK ROOT' 'TITLE'
	printf '%-24s %-12s %-16s %s\n' '------------------------' '------------' '----------------' '-----'
	awk -F '\t' '
		NR == FNR {if ($0 !~ /^#/ && NF >= 2) title[$1] = $2; next}
		$0 !~ /^#/ && NF >= 4 {printf "%-24s %-12s %-16s %s\n", $1, $2, $3, title[$1]}
	' "$(project_plan_definition_file)" "$(project_plan_state_file)"
fi
printf '\n'
printf '%-32s %-12s %-10s %-28s %-10s\n' 'TASK' 'STATE' 'PROGRESS' 'OWNER' 'AGE'
printf '%-32s %-12s %-10s %-28s %-10s\n' '--------------------------------' '------------' '----------' '----------------------------' '----------'

shopt -s nullglob
found=0
accepted_count=0
checkpointed_count=0
active_count=0
aborted_count=0
blocked_count=0
replan_count=0
task_rows=()

for file in "$dir/tasks/$PROJECT-task-"*.ready.md; do
	found=1
	active_count=$((active_count + 1))
	task_id="$(task_id_from_filename "$file")"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'READY' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/running/$PROJECT-task-"*.running.md; do
	found=1
	active_count=$((active_count + 1))
	task_id="$(task_id_from_filename "$file")"
	base="$(task_base "$task_id")"
	progress="$(task_progress_percent "$task_id")%"
	lease="$dir/control/$base.lease"
	owner='unknown'
	age='unknown'
	if [[ -f "$lease" ]]; then
		owner="$(lease_value "$lease" owner)"
		heartbeat_epoch="$(lease_value "$lease" heartbeat_epoch)"
		if [[ -n "$heartbeat_epoch" ]]; then
			age="$(( $(epoch_now) - heartbeat_epoch ))s"
		fi
	fi
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'RUNNING' "$progress" "$owner" "$age"
	task_rows+=("$task_row")
done

for file in "$dir/results/$PROJECT-task-"*.result.md; do
	found=1
	active_count=$((active_count + 1))
	task_id="$(task_id_from_filename "$file")"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'REVIEW' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/archive/$PROJECT-task-"*.accepted.md; do
	found=1
	accepted_count=$((accepted_count + 1))
	name="${file##*/}"
	task_id="${name#${PROJECT}-task-}"
	task_id="${task_id%.accepted.md}"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'ACCEPTED' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/archive/$PROJECT-task-"*.checkpointed.md; do
	found=1
	checkpointed_count=$((checkpointed_count + 1))
	name="${file##*/}"
	task_id="${name#${PROJECT}-task-}"
	task_id="${task_id%.checkpointed.md}"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'CHECKPOINTED' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/control/$PROJECT-task-"*.abort.md; do
	found=1
	aborted_count=$((aborted_count + 1))
	name="${file##*/}"
	task_id="${name#${PROJECT}-task-}"
	task_id="${task_id%.abort.md}"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'ABORTED' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/control/progress/$PROJECT-task-"*.blocked.md; do
	found=1
	blocked_count=$((blocked_count + 1))
	name="${file##*/}"
	task_id="${name#${PROJECT}-task-}"
	task_id="${task_id%.blocked.md}"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'BLOCKED' "$progress" '-' '-'
	task_rows+=("$task_row")
done

for file in "$dir/control/progress/$PROJECT-task-"*.needs-replan.md; do
	found=1
	replan_count=$((replan_count + 1))
	name="${file##*/}"
	task_id="${name#${PROJECT}-task-}"
	task_id="${task_id%.needs-replan.md}"
	progress="$(task_progress_percent "$task_id")%"
	printf -v task_row '%-32s %-12s %-10s %-28s %-10s' "$task_id" 'NEEDS_REPLAN' "$progress" '-' '-'
	task_rows+=("$task_row")
done

if (( found == 0 )); then
	printf '%s\n' '(no tasks)'
else
	for ((row_index = ${#task_rows[@]} - 1; row_index >= 0; row_index--)); do
		printf '%s\n' "${task_rows[row_index]}"
	done
fi

if project_completion_recorded && project_plan_all_complete; then
	printf '\nProject status: COMPLETE. Every project-plan item is accepted.\n'
elif (( replan_count > 0 )); then
	printf '\nProject status: NEEDS_REPLAN. Verified checkpoints are preserved; reassess and narrow the active root before resuming.\n'
elif (( blocked_count > 0 )); then
	printf '\nProject status: BLOCKED. A root task requires human intervention before planning can continue.\n'
elif project_is_blocked; then
	printf '\nProject status: BLOCKED. The Oracle requires human approval before planning can continue.\n'
elif project_plan_exists && (( active_count == 0 && aborted_count == 0 )) && ! project_plan_all_complete; then
	printf '\nProject status: INCOMPLETE. No task is active; manager planning is required for the next plan item.\n'
elif project_completion_recorded; then
	printf '\nProject status: INCOMPLETE. Ignoring an invalid legacy completion marker because the project plan is absent or unfinished.\n'
fi

if (( checkpointed_count > 0 )); then
	printf '\nVerified checkpoints: %s\n' "$checkpointed_count"
fi

printf '\n%s\n' "$project_progress_line"
