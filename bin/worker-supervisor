#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
require_worker_codex
trace_init worker_supervisor
trace_script_start "$@"
dir="$(project_dir)"
worker_invoker="${HARNESS_WORKER_INVOKER:-$HARNESS_BIN/worker-invoke-task}"
[[ -x "$worker_invoker" ]] || die "worker invoker is not executable: $worker_invoker"

exec 8>"$dir/control/worker-supervisor.lock"
flock -n 8 || die "a worker supervisor is already running for project: $PROJECT"
printf '%s\n' "$$" > "$dir/control/worker-supervisor.pid"
printf '%s\n' "$HARNESS_ENV_FILE" > "$dir/control/worker-supervisor.env-file"
watch_pid=""
cleanup()
{
	local status="${worker_supervisor_exit_status:-0}"
	if [[ -n "$watch_pid" ]]; then
		kill "$watch_pid" 2>/dev/null || true
	fi
	rm -f "$dir/control/worker-supervisor.pid" "$dir/control/worker-supervisor.env-file"
	trace_script_exit "$status"
}
trap 'cleanup; exit 0' INT TERM
trap 'worker_supervisor_exit_status=$?; cleanup' EXIT

fingerprint()
{
	local file="$1"
	stat -c '%i:%s:%Y' "$file"
}

process_tasks()
{
	local file task_id base marker current previous status alert tmp
	shopt -s nullglob
	for file in "$dir/tasks/$PROJECT-task-"*.ready.md; do
		task_id="$(task_id_from_filename "$file")"
		base="$(task_base "$task_id")"
		marker="$dir/control/$base.worker-triggered"
		current="$(fingerprint "$file")"
		previous=""
		[[ ! -f "$marker" ]] || previous="$(kv_file_value "$marker" fingerprint)"
		[[ "$current" != "$previous" ]] || continue

		tmp="$marker.tmp.$$"
		{
			printf 'fingerprint=%s\n' "$current"
			printf 'triggered_at=%s\n' "$(timestamp_utc)"
		} > "$tmp"
		chmod 600 "$tmp"
		mv "$tmp" "$marker"
		log_event "WORKER_SUPERVISOR_TRIGGER task=$task_id fingerprint=$current"
		trace_event WORKER_SUPERVISOR_INVOKE "task_id=$task_id" "fingerprint=$current" "worker_invoker=$worker_invoker"

		set +e
		"$worker_invoker" "$HARNESS_ENV_FILE" "$task_id"
		status=$?
		set -e
		trace_event WORKER_SUPERVISOR_INVOKE_EXIT "task_id=$task_id" "status=$status"
		if (( status != 0 )); then
			alert="$dir/control/$base.worker-supervisor-failed.md"
			tmp="$alert.tmp.$$"
			{
				printf '# Worker Supervisor Invocation Failed\n\n'
				printf 'Project: %s\n\n' "$PROJECT"
				printf 'Task-ID: %s\n\n' "$task_id"
				printf 'Environment-File: %s\n\n' "$HARNESS_ENV_FILE"
				printf 'Failed-At: %s\n\n' "$(timestamp_utc)"
				printf 'Exit-Status: %s\n\n' "$status"
				printf 'Confirmed model-capacity errors are retried inside worker-invoke-task. This failure was non-retryable or exhausted the configured retry limit.\n'
			} > "$tmp"
			chmod 600 "$tmp"
			mv "$tmp" "$alert"
			printf 'Worker invocation failed for task %s; see %s\n' "$task_id" "$alert" >&2
		fi
	done
}

handle_project_completion()
{
	local completion_file completed_task
	completion_file="$(project_complete_file)"
	[[ -f "$completion_file" ]] || return 1
	completed_task="$(kv_file_value "$completion_file" task_id)"
	log_event "WORKER_SUPERVISOR_PROJECT_COMPLETED task=$completed_task file=$completion_file"
	trace_event WORKER_SUPERVISOR_PROJECT_COMPLETED "task_id=$completed_task" "completion_file=$completion_file"
	terminate_descendants_of_pid "$$"
	return 0
}

log_event "WORKER_SUPERVISOR_STARTED pid=$$ env_file=$HARNESS_ENV_FILE"
printf 'Worker supervisor started for %s with PID %s. No worker LLM is running while idle.\n' "$PROJECT" "$$"

while true; do
	if handle_project_completion; then
		break
	fi
	process_tasks
	if handle_project_completion; then
		break
	fi
	if [[ "$HARNESS_USE_INOTIFY" == "1" ]] && command -v inotifywait >/dev/null 2>&1; then
		trace_event WORKER_SUPERVISOR_WATCH_WAIT_BEGIN "mode=inotify" "timeout=$HARNESS_POLL_SECONDS"
		inotifywait -q -t "$HARNESS_POLL_SECONDS" -e moved_to -e create -e delete "$dir/tasks" "$dir/control" >/dev/null 2>&1 &
		watch_pid=$!
		set +e
		wait "$watch_pid"
		watch_status=$?
		set -e
		trace_event WORKER_SUPERVISOR_WATCH_WAIT_END "mode=inotify" "watch_pid=$watch_pid" "status=$watch_status"
		watch_pid=""
	else
		trace_event WORKER_SUPERVISOR_WATCH_WAIT_BEGIN "mode=poll" "timeout=$HARNESS_POLL_SECONDS"
		sleep "$HARNESS_POLL_SECONDS"
		trace_event WORKER_SUPERVISOR_WATCH_WAIT_END "mode=poll" "status=0"
	fi
done
