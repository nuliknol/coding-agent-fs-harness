#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 2 ]] || usage
load_harness_env "$1"
task_id="$2"
ensure_project
require_repository
require_worker_codex
trace_init worker_invoke_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
write_worker_snapshot

dir="$(project_dir)"
base="$(task_base "$task_id")"
ready="$dir/tasks/$base.ready.md"
[[ -f "$ready" ]] || die "task is not ready: $task_id"

session="$("$HARNESS_BIN/harness-new-session" "$HARNESS_ENV_FILE" worker)"
trace_event WORKER_SESSION_CREATED "task_id=$task_id" "session=$session"
claim_output="$("$HARNESS_BIN/worker-claim-task" "$HARNESS_ENV_FILE" "$task_id" "$session")"
task_file="$(printf '%s\n' "$claim_output" | awk -F= '$1 == "TASK_FILE" {sub(/^[^=]*=/, ""); print; exit}')"
[[ -f "$task_file" ]] || die "claimed task file is missing: $task_file"
initialize_task_progress "$task_id" "$task_file"
task_root="$(task_root_id "$task_id")"
progress_file="$(task_progress_file "$task_root")"
root_assignment_file="$(task_root_assignment_file "$task_root")"
starting_progress="$(task_progress_percent "$task_root")"
development_policy_file="$REPOSITORY/design/development-policy.txt"
[[ -f "$development_policy_file" ]] || development_policy_file=""
trace_event WORKER_TASK_CLAIMED "task_id=$task_id" "session=$session" "task_file=$task_file"

worker_thread_file="$(worker_thread_state_file "$task_root")"
worker_context_mode="fresh"
worker_context_reason="no_retained_thread"
worker_resume_thread_id=""
worker_thread_rejections=0
if (( HARNESS_REUSE_WORKER_THREADS == 0 )); then
	worker_context_reason="reuse_disabled"
elif [[ "$task_id" == "$task_root" ]]; then
	worker_context_reason="new_root_task"
elif grep -Eq '^Worker-Context:[[:space:]]*FRESH[[:space:]]*$' "$task_file"; then
	worker_context_reason="assignment_requested_fresh"
elif [[ -f "$worker_thread_file" ]]; then
	worker_resume_thread_id="$(kv_file_value "$worker_thread_file" thread_id 2>/dev/null || true)"
	worker_thread_rejections="$(kv_file_value "$worker_thread_file" rejection_count 2>/dev/null || printf 0)"
	[[ "$worker_thread_rejections" =~ ^[0-9]+$ ]] || worker_thread_rejections=0
	if [[ ! "$worker_resume_thread_id" =~ ^[A-Za-z0-9-]+$ ]]; then
		worker_resume_thread_id=""
		worker_context_reason="invalid_retained_thread"
	elif (( HARNESS_WORKER_THREAD_MAX_REJECTIONS > 0 && worker_thread_rejections >= HARNESS_WORKER_THREAD_MAX_REJECTIONS )); then
		worker_resume_thread_id=""
		worker_context_reason="rejection_rotation_limit"
	else
		worker_context_mode="resumed"
		worker_context_reason="same_root_rejection"
	fi
fi

closure_mode=0
if (( HARNESS_CLOSURE_MODE_ENABLED == 1 )) &&
	[[ "$task_id" != "$task_root" ]] &&
	(( starting_progress >= HARNESS_CLOSURE_MODE_MIN_PROGRESS && starting_progress < 100 )); then
	closure_mode=1
fi
log_event "WORKER_CONTEXT_SELECTED task=$task_id root=$task_root mode=$worker_context_mode reason=$worker_context_reason thread_id=${worker_resume_thread_id:-none} retained_rejections=$worker_thread_rejections closure_mode=$closure_mode"
trace_event WORKER_CONTEXT_SELECTED "task_id=$task_id" "task_root=$task_root" "mode=$worker_context_mode" "reason=$worker_context_reason" "thread_id=${worker_resume_thread_id:-}" "retained_rejections=$worker_thread_rejections" "closure_mode=$closure_mode"

prompt_file="$dir/control/$base.worker.prompt.md"
cat > "$prompt_file.tmp.$$" <<PROMPT
Read $HARNESS_HOME/prompts/worker-agent-event-driven.md and follow it.

HARNESS_BIN=$HARNESS_BIN
ENV_FILE=$HARNESS_ENV_FILE
PROJECT=$PROJECT
PROJECT_TMP_DIR=$PROJECT_TMP_DIR
REPOSITORY=$REPOSITORY
TASK_ID=$task_id
TASK_FILE=$task_file
TASK_ROOT=$task_root
ROOT_ASSIGNMENT_FILE=$root_assignment_file
PROGRESS_FILE=$progress_file
STARTING_PROGRESS_PERCENT=$starting_progress
DEVELOPMENT_POLICY_FILE=$development_policy_file
SESSION=$session
WORKER_CONTEXT_MODE=$worker_context_mode
WORKER_CONTEXT_REASON=$worker_context_reason
WORKER_RETAINED_REJECTIONS=$worker_thread_rejections
CLOSURE_MODE=$closure_mode
CLOSURE_MAX_FIXES=$HARNESS_CLOSURE_MODE_MAX_FIXES
CLOSURE_MAX_SMOKE_RUNS=$HARNESS_CLOSURE_MODE_MAX_SMOKE_RUNS

The task is already claimed by this launcher. Read DEVELOPMENT_POLICY_FILE when present, then ROOT_ASSIGNMENT_FILE, PROGRESS_FILE, and TASK_FILE completely. The current files are authoritative even when this turn resumes an earlier worker conversation. Preserve verified work and continue from STARTING_PROGRESS_PERCENT rather than reimplementing the root task from zero. Implement exactly the remaining bounded assignment, validate only the developed feature according to the prototype policy, write any scratch files and the result report under PROJECT_TMP_DIR, publish the result with worker-complete-task, and terminate. Do not wait for another task. Do not create, stage, or commit Git changes.
PROMPT
if (( closure_mode == 1 )); then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Bounded closure mode is active because this continuation starts at ${starting_progress}%. Within this one turn, close the same focused root acceptance gate using at most $HARNESS_CLOSURE_MODE_MAX_FIXES small evidence-backed corrections and at most $HARNESS_CLOSURE_MODE_MAX_SMOKE_RUNS total executions of the assigned focused smoke. A manager-authored phrase such as "exactly once" or "do not rerun" does not reduce this closure budget; the human-owned specification and immutable root scope remain authoritative.

Start with the current first failure. Diagnose before editing, apply only the smallest correction directly implicated by that failure, rebuild the affected target, and use the next focused-smoke execution. Repeat only while the failure remains inside TASK_ROOT and the correction does not require a new public API, new scope, relaxed acceptance criterion, fabricated fallback, increased capacity without evidence, or an explicitly prohibited file/behavior. A directly implicated additional root-scope implementation file may be changed when the runtime diagnostic or stack proves it necessary; record why it is inside the closure boundary. Stop immediately on a passing smoke, exhausted budget, an out-of-root failure, or a required design/authority choice. Never substitute broad tests for the single focused gate. Report the exact number of fixes and smoke executions.
PROMPT
fi
if codex_model_requires_narrow_prompt "$WORKER_MODEL"; then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Context: authorized local development in my own repository. Task type: benign software engineering. Do not perform offensive security, credential extraction, vulnerability exploitation, malware behavior, unauthorized access, network scanning, or bypassing security controls. Use only the listed local project files needed for the requested implementation: TASK_FILE and the files explicitly referenced by that bounded assignment.
PROMPT
fi
chmod 600 "$prompt_file.tmp.$$"
mv "$prompt_file.tmp.$$" "$prompt_file"

result="$dir/results/$base.result.md"
running="$dir/running/$base.running.md"
lease="$dir/control/$base.lease"
assignment_archive="$dir/archive/$base.assignment.md"
staged_result="$dir/control/$base.direct-result.$$"
protocol_reason=""
json_log=""
stderr_log=""
classification=""
last_message=""
status=0
attempt=1
provider_retries=0
quota_waits=0
fallback_stage=0
current_model="$WORKER_MODEL"
heartbeat_pid=""

completion_committed()
{
	[[ -f "$result" && ! -e "$running" && ! -e "$lease" && -f "$assignment_archive" ]]
}

normalize_direct_result()
{
	local normalize_status
	if [[ -f "$result" && -f "$running" && -f "$lease" && ! -e "$assignment_archive" ]]; then
		mv "$result" "$staged_result"
		set +e
		"$HARNESS_BIN/worker-complete-task" "$HARNESS_ENV_FILE" "$task_id" "$session" "$staged_result" >/dev/null
		normalize_status=$?
		set -e
		if (( normalize_status == 0 )); then
			rm -f "$staged_result"
			log_event "WORKER_DIRECT_RESULT_NORMALIZED task=$task_id session=$session"
		else
			if [[ ! -e "$result" && -f "$staged_result" ]]; then
				mv "$staged_result" "$result"
			fi
			protocol_reason="direct_result_normalization_failed:$normalize_status"
		fi
	fi
}

normalize_last_message_result()
{
	local normalize_status
	if (( status == 0 )) &&
		[[ -s "$last_message" && ! -f "$result" && -f "$running" && -f "$lease" && ! -e "$assignment_archive" ]]; then
		set +e
		"$HARNESS_BIN/worker-complete-task" "$HARNESS_ENV_FILE" "$task_id" "$session" "$last_message" >/dev/null
		normalize_status=$?
		set -e
		if (( normalize_status == 0 )); then
			log_event "WORKER_LAST_MESSAGE_RESULT_NORMALIZED task=$task_id session=$session"
		else
			protocol_reason="last_message_result_normalization_failed:$normalize_status"
		fi
	fi
}

heartbeat_loop()
{
	while true; do
		sleep "$WORKER_HEARTBEAT_SECONDS"
		"$HARNESS_BIN/worker-heartbeat" "$HARNESS_ENV_FILE" "$task_id" "$session" >/dev/null 2>&1 || break
	done
}

cleanup_heartbeat()
{
	if [[ -n "$heartbeat_pid" ]]; then
		kill "$heartbeat_pid" 2>/dev/null || true
		wait "$heartbeat_pid" 2>/dev/null || true
		heartbeat_pid=""
	fi
}
trap cleanup_heartbeat EXIT
trap 'cleanup_heartbeat; exit 130' INT
trap 'cleanup_heartbeat; exit 143' TERM

heartbeat_loop &
heartbeat_pid=$!
trace_event WORKER_HEARTBEAT_STARTED "task_id=$task_id" "session=$session" "heartbeat_pid=$heartbeat_pid" "interval=$WORKER_HEARTBEAT_SECONDS"

while true; do
	stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
	attempt_label="$(printf '%03d' "$attempt")"
	json_log="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.jsonl"
	stderr_log="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.stderr.log"
	last_message="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.md"

	log_event "WORKER_INVOCATION_STARTED task=$task_id session=$session model=$WORKER_MODEL attempt=$attempt"
	trace_event WORKER_INVOCATION_ATTEMPT "task_id=$task_id" "session=$session" "attempt=$attempt" "thread_id=${worker_resume_thread_id:-}" "json_log=$json_log" "last_message=$last_message"
	set +e
	trace_event CODEX_EXEC_START "role=worker" "task_id=$task_id" "session=$session" "attempt=$attempt" "mode=$([[ -n "$worker_resume_thread_id" ]] && printf resume || printf fresh)" "thread_id=${worker_resume_thread_id:-}" "json_log=$json_log" "stderr_log=$stderr_log" "last_message=$last_message" "model=$current_model"
	resume_args=()
	[[ -z "$worker_resume_thread_id" ]] || resume_args=(resume "$worker_resume_thread_id")
	"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" worker "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$last_message" "${resume_args[@]}"
	status=$?
	set -e
	observed_thread_id="$(codex_thread_id_from_jsonl "$json_log" 2>/dev/null || true)"
	if [[ "$observed_thread_id" =~ ^[A-Za-z0-9-]+$ ]]; then
		worker_resume_thread_id="$observed_thread_id"
	fi
	classification="$(kv_file_value "${json_log%.jsonl}.classification" classification 2>/dev/null || true)"
	trace_event CODEX_EXEC_END "role=worker" "task_id=$task_id" "session=$session" "attempt=$attempt" "status=$status" "classification=${classification:-unknown}" "json_log=$json_log" "stderr_log=$stderr_log" "last_message=$last_message"

	normalize_direct_result
	normalize_last_message_result
	if completion_committed; then
		cleanup_heartbeat
		log_event "WORKER_INVOCATION_FINISHED task=$task_id session=$session status=$status result=published attempt=$attempt"
		trace_event WORKER_RESULT_PUBLISHED "task_id=$task_id" "session=$session" "attempt=$attempt" "status=$status" "result=$result"
		printf 'Worker completed task %s and published its result.\n' "$task_id"
		exit 0
	fi

	retry_kind="$(codex_provider_retry_kind "$classification" 2>/dev/null || true)"
	if [[ -n "$retry_kind" ]]; then
		retry_delay="$(codex_provider_retry_delay "$classification")"
		provider_retries=$((provider_retries + 1))
		[[ "$retry_kind" != quota ]] || quota_waits=$((quota_waits + 1))
		log_event "WORKER_PROVIDER_WAIT task=$task_id session=$session kind=$retry_kind attempt=$attempt retry=$provider_retries delay_seconds=$retry_delay classification=$classification"
		if [[ "$retry_kind" == quota ]]; then
			printf 'Worker task %s has no provider quota; state and heartbeat are preserved. Checking again in %s seconds (quota wait %s).\n' "$task_id" "$retry_delay" "$quota_waits" >&2
		else
			printf 'Worker task %s hit a transient provider/network failure; retrying in %s seconds.\n' "$task_id" "$retry_delay" >&2
		fi
		sleep "$retry_delay"
		attempt=$((attempt + 1))
		log_event "WORKER_PROVIDER_RETRY_STARTED task=$task_id session=$session kind=$retry_kind attempt=$attempt retry=$provider_retries"
		trace_event WORKER_PROVIDER_RETRY "task_id=$task_id" "session=$session" "kind=$retry_kind" "attempt=$attempt" "retry=$provider_retries"
		continue
	fi

	# Terra/GPT-5.6 gets exactly one narrowed retry, then one stable-model
	# fallback for model-layer failures only. Provider, authentication, sandbox,
	# configuration, and protocol failures never enter this branch.
	if codex_model_requires_narrow_prompt "$current_model" && [[ "$classification" == model_refusal_or_blocked_content ]]; then
		if (( fallback_stage == 0 )); then
			fallback_stage=1
			printf '\nRetry scope: perform only the single bounded assignment in TASK_FILE. Do not inspect unrelated directories or broaden the task.\n' >> "$prompt_file"
			attempt=$((attempt + 1))
			log_event "WORKER_TERRA_NARROW_RETRY task=$task_id session=$session classification=$classification"
			continue
		fi
		if (( fallback_stage == 1 )) && [[ "$WORKER_FALLBACK_MODEL" != "$current_model" ]]; then
			fallback_stage=2
			current_model="$WORKER_FALLBACK_MODEL"
			attempt=$((attempt + 1))
			log_event "WORKER_MODEL_FALLBACK task=$task_id session=$session classification=$classification model=$current_model"
			continue
		fi
	fi

	break
done

cleanup_heartbeat

if [[ -z "$protocol_reason" ]]; then
	if [[ ! -f "$result" ]]; then
		protocol_reason="result_not_published"
	else
		protocol_reason="completion_state_inconsistent"
	fi
fi

alert="$dir/control/$base.worker-failed.md"
cat > "$alert.tmp.$$" <<ALERT
# Worker Invocation Failed

Project: $PROJECT

Task-ID: $task_id

Session: $session

Environment-File: $HARNESS_ENV_FILE

Failed-At: $(timestamp_utc)

Codex-Exit-Status: $status

Protocol-Reason: $protocol_reason

JSONL-Log: $json_log

Stderr-Log: $stderr_log

Classification: ${classification:-unknown}

Partial-Edits: $(kv_file_value "${json_log%.jsonl}.classification" partial_edits 2>/dev/null || printf unknown)

Attempts: $attempt

Provider-Retries: $provider_retries

Quota-Waits: $quota_waits

The completion transaction is not committed. Provider quota and transient provider/network failures retry indefinitely while preserving task ownership. This failure was classified as terminal, local, configuration/protocol, or an actual agent failure. Inspect the log and filesystem state, then reset, repair, or abort the task explicitly.
ALERT
chmod 600 "$alert.tmp.$$"
mv "$alert.tmp.$$" "$alert"
if (( status == 0 )); then
	log_event "WORKER_PROTOCOL_FAILED task=$task_id session=$session status=$status reason=$protocol_reason attempts=$attempt"
	trace_event WORKER_PROTOCOL_FAILED "task_id=$task_id" "session=$session" "status=$status" "reason=$protocol_reason" "attempts=$attempt" "json_log=$json_log"
else
	log_event "WORKER_PROCESS_FAILED task=$task_id session=$session status=$status reason=$protocol_reason attempts=$attempt"
	trace_event WORKER_PROCESS_FAILED "task_id=$task_id" "session=$session" "status=$status" "reason=$protocol_reason" "attempts=$attempt" "json_log=$json_log"
fi
printf 'Worker invocation failed for task %s; see %s\n' "$task_id" "$alert" >&2
if (( status == 0 )); then
	exit 70
fi
exit "$status"
