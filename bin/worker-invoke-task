#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE TASK_ID\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 2 ]] || usage
load_harness_env "$1"
task_id="$2"
ensure_project
require_repository
require_worker_codex
trace_init worker_invoke_task
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
validate_task_id "$task_id"
write_worker_snapshot

dir="$(project_dir)"
base="$(task_base "$task_id")"
ready="$dir/tasks/$base.ready.md"
[[ -f "$ready" ]] || die "task is not ready: $task_id"

session="$("$HARNESS_BIN/harness-new-session" "$HARNESS_ENV_FILE" worker)"
trace_event WORKER_SESSION_CREATED "task_id=$task_id" "session=$session"
claim_output="$("$HARNESS_BIN/worker-claim-task" "$HARNESS_ENV_FILE" "$task_id" "$session")"
task_file="$(printf '%s\n' "$claim_output" | awk -F= '$1 == "TASK_FILE" {sub(/^[^=]*=/, ""); print; exit}')"
[[ -f "$task_file" ]] || die "claimed task file is missing: $task_file"
trace_event WORKER_TASK_CLAIMED "task_id=$task_id" "session=$session" "task_file=$task_file"

prompt_file="$dir/control/$base.worker.prompt.md"
cat > "$prompt_file.tmp.$$" <<PROMPT
Read $HARNESS_HOME/prompts/worker-agent-event-driven.md and follow it.

HARNESS_BIN=$HARNESS_BIN
ENV_FILE=$HARNESS_ENV_FILE
PROJECT=$PROJECT
PROJECT_TMP_DIR=$PROJECT_TMP_DIR
REPOSITORY=$REPOSITORY
TASK_ID=$task_id
TASK_FILE=$task_file
SESSION=$session

The task is already claimed by this launcher. Read TASK_FILE completely, implement exactly that assignment, validate it, write any scratch files and the result report under PROJECT_TMP_DIR, publish the result with worker-complete-task, and terminate. Do not wait for another task. Do not create, stage, or commit Git changes.
PROMPT
if codex_model_requires_narrow_prompt "$WORKER_MODEL"; then
	cat >> "$prompt_file.tmp.$$" <<PROMPT

Context: authorized local development in my own repository. Task type: benign software engineering. Do not perform offensive security, credential extraction, vulnerability exploitation, malware behavior, unauthorized access, network scanning, or bypassing security controls. Use only the listed local project files needed for the requested implementation: TASK_FILE and the files explicitly referenced by that bounded assignment.
PROMPT
fi
chmod 600 "$prompt_file.tmp.$$"
mv "$prompt_file.tmp.$$" "$prompt_file"

result="$dir/results/$base.result.md"
running="$dir/running/$base.running.md"
lease="$dir/control/$base.lease"
assignment_archive="$dir/archive/$base.assignment.md"
staged_result="$dir/control/$base.direct-result.$$"
protocol_reason=""
json_log=""
stderr_log=""
classification=""
last_message=""
status=0
attempt=1
capacity_retries=0
fallback_stage=0
current_model="$WORKER_MODEL"
heartbeat_pid=""

completion_committed()
{
	[[ -f "$result" && ! -e "$running" && ! -e "$lease" && -f "$assignment_archive" ]]
}

normalize_direct_result()
{
	local normalize_status
	if [[ -f "$result" && -f "$running" && -f "$lease" && ! -e "$assignment_archive" ]]; then
		mv "$result" "$staged_result"
		set +e
		"$HARNESS_BIN/worker-complete-task" "$HARNESS_ENV_FILE" "$task_id" "$session" "$staged_result" >/dev/null
		normalize_status=$?
		set -e
		if (( normalize_status == 0 )); then
			rm -f "$staged_result"
			log_event "WORKER_DIRECT_RESULT_NORMALIZED task=$task_id session=$session"
		else
			if [[ ! -e "$result" && -f "$staged_result" ]]; then
				mv "$staged_result" "$result"
			fi
			protocol_reason="direct_result_normalization_failed:$normalize_status"
		fi
	fi
}

normalize_last_message_result()
{
	local normalize_status
	if (( status == 0 )) &&
		[[ -s "$last_message" && ! -f "$result" && -f "$running" && -f "$lease" && ! -e "$assignment_archive" ]]; then
		set +e
		"$HARNESS_BIN/worker-complete-task" "$HARNESS_ENV_FILE" "$task_id" "$session" "$last_message" >/dev/null
		normalize_status=$?
		set -e
		if (( normalize_status == 0 )); then
			log_event "WORKER_LAST_MESSAGE_RESULT_NORMALIZED task=$task_id session=$session"
		else
			protocol_reason="last_message_result_normalization_failed:$normalize_status"
		fi
	fi
}

heartbeat_loop()
{
	while true; do
		sleep "$WORKER_HEARTBEAT_SECONDS"
		"$HARNESS_BIN/worker-heartbeat" "$HARNESS_ENV_FILE" "$task_id" "$session" >/dev/null 2>&1 || break
	done
}

cleanup_heartbeat()
{
	if [[ -n "$heartbeat_pid" ]]; then
		kill "$heartbeat_pid" 2>/dev/null || true
		wait "$heartbeat_pid" 2>/dev/null || true
		heartbeat_pid=""
	fi
}
trap cleanup_heartbeat EXIT
trap 'cleanup_heartbeat; exit 130' INT
trap 'cleanup_heartbeat; exit 143' TERM

heartbeat_loop &
heartbeat_pid=$!
trace_event WORKER_HEARTBEAT_STARTED "task_id=$task_id" "session=$session" "heartbeat_pid=$heartbeat_pid" "interval=$WORKER_HEARTBEAT_SECONDS"

while true; do
	stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
	attempt_label="$(printf '%03d' "$attempt")"
	json_log="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.jsonl"
	stderr_log="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.stderr.log"
	last_message="$dir/logs/worker-task-$task_id-$stamp-attempt-$attempt_label.md"

	log_event "WORKER_INVOCATION_STARTED task=$task_id session=$session model=$WORKER_MODEL attempt=$attempt"
	trace_event WORKER_INVOCATION_ATTEMPT "task_id=$task_id" "session=$session" "attempt=$attempt" "json_log=$json_log" "last_message=$last_message"
	set +e
	trace_event CODEX_EXEC_START "role=worker" "task_id=$task_id" "session=$session" "attempt=$attempt" "json_log=$json_log" "stderr_log=$stderr_log" "last_message=$last_message" "model=$current_model"
	"$HARNESS_BIN/codex-exec-jsonl" "$HARNESS_ENV_FILE" worker "$current_model" "$prompt_file" "$json_log" "$stderr_log" "$last_message"
	status=$?
	set -e
	classification="$(kv_file_value "${json_log%.jsonl}.classification" classification 2>/dev/null || true)"
	trace_event CODEX_EXEC_END "role=worker" "task_id=$task_id" "session=$session" "attempt=$attempt" "status=$status" "classification=${classification:-unknown}" "json_log=$json_log" "stderr_log=$stderr_log" "last_message=$last_message"

	normalize_direct_result
	normalize_last_message_result
	if completion_committed; then
		cleanup_heartbeat
		log_event "WORKER_INVOCATION_FINISHED task=$task_id session=$session status=$status result=published attempt=$attempt"
		trace_event WORKER_RESULT_PUBLISHED "task_id=$task_id" "session=$session" "attempt=$attempt" "status=$status" "result=$result"
		printf 'Worker completed task %s and published its result.\n' "$task_id"
		exit 0
	fi

	# Terra/GPT-5.6 gets exactly one narrowed retry, then one stable-model
	# fallback. This deliberately does not replay a broad autonomous request.
	if codex_model_requires_narrow_prompt "$current_model" && [[ "$classification" != success ]]; then
		if (( fallback_stage == 0 )); then
			fallback_stage=1
			printf '\nRetry scope: perform only the single bounded assignment in TASK_FILE. Do not inspect unrelated directories or broaden the task.\n' >> "$prompt_file"
			attempt=$((attempt + 1))
			log_event "WORKER_TERRA_NARROW_RETRY task=$task_id session=$session classification=$classification"
			continue
		fi
		if (( fallback_stage == 1 )) && [[ "$WORKER_FALLBACK_MODEL" != "$current_model" ]]; then
			fallback_stage=2
			current_model="$WORKER_FALLBACK_MODEL"
			attempt=$((attempt + 1))
			log_event "WORKER_MODEL_FALLBACK task=$task_id session=$session classification=$classification model=$current_model"
			continue
		fi
	fi

	if (( status != 0 )) && codex_log_has_capacity_error "$json_log" && capacity_retry_allowed "$capacity_retries"; then
		capacity_retries=$((capacity_retries + 1))
		log_event "WORKER_CAPACITY_RETRY_SCHEDULED task=$task_id session=$session attempt=$attempt retry=$capacity_retries delay_seconds=$HARNESS_CAPACITY_RETRY_SECONDS"
		printf 'Worker model is at capacity for task %s; retrying in %s seconds.\n' "$task_id" "$HARNESS_CAPACITY_RETRY_SECONDS" >&2
		sleep "$HARNESS_CAPACITY_RETRY_SECONDS"
		attempt=$((attempt + 1))
		log_event "WORKER_CAPACITY_RETRY_STARTED task=$task_id session=$session attempt=$attempt retry=$capacity_retries"
		trace_event WORKER_RETRY "task_id=$task_id" "session=$session" "attempt=$attempt" "retry=$capacity_retries"
		continue
	fi

	break
done

cleanup_heartbeat

if [[ -z "$protocol_reason" ]]; then
	if [[ ! -f "$result" ]]; then
		protocol_reason="result_not_published"
	else
		protocol_reason="completion_state_inconsistent"
	fi
fi

alert="$dir/control/$base.worker-failed.md"
cat > "$alert.tmp.$$" <<ALERT
# Worker Invocation Failed

Project: $PROJECT

Task-ID: $task_id

Session: $session

Environment-File: $HARNESS_ENV_FILE

Failed-At: $(timestamp_utc)

Codex-Exit-Status: $status

Protocol-Reason: $protocol_reason

JSONL-Log: $json_log

Stderr-Log: $stderr_log

Classification: ${classification:-unknown}

Partial-Edits: $(kv_file_value "${json_log%.jsonl}.classification" partial_edits 2>/dev/null || printf unknown)

Attempts: $attempt

Capacity-Retries: $capacity_retries

The completion transaction is not committed. A confirmed model-capacity error is retried automatically after $HARNESS_CAPACITY_RETRY_SECONDS seconds. This failure was either non-retryable or exceeded HARNESS_CAPACITY_MAX_RETRIES. Inspect the log and filesystem state, then reset, repair, or abort the task explicitly.
ALERT
chmod 600 "$alert.tmp.$$"
mv "$alert.tmp.$$" "$alert"
if (( status == 0 )); then
	log_event "WORKER_PROTOCOL_FAILED task=$task_id session=$session status=$status reason=$protocol_reason attempts=$attempt"
	trace_event WORKER_PROTOCOL_FAILED "task_id=$task_id" "session=$session" "status=$status" "reason=$protocol_reason" "attempts=$attempt" "json_log=$json_log"
else
	log_event "WORKER_PROCESS_FAILED task=$task_id session=$session status=$status reason=$protocol_reason attempts=$attempt"
	trace_event WORKER_PROCESS_FAILED "task_id=$task_id" "session=$session" "status=$status" "reason=$protocol_reason" "attempts=$attempt" "json_log=$json_log"
fi
printf 'Worker invocation failed for task %s; see %s\n' "$task_id" "$alert" >&2
if (( status == 0 )); then
	exit 70
fi
exit "$status"
