#!/usr/bin/env bash

set -Eeuo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/harness-common.sh"

usage()
{
	printf 'Usage: %s ENV_FILE\n' "${0##*/}" >&2
	exit 2
}

[[ $# -eq 1 ]] || usage
load_harness_env "$1"
ensure_project
trace_init worker_supervisor_start
trace_script_start "$@"
trap 'trace_script_exit $?' EXIT
dir="$(project_dir)"
pid_file="$dir/control/worker-supervisor.pid"

if [[ -f "$pid_file" ]]; then
	pid="$(cat "$pid_file")"
	if kill -0 "$pid" 2>/dev/null; then
		trace_event WORKER_SUPERVISOR_START_SKIPPED "pid=$pid" "reason=already_running"
		printf 'Worker supervisor is already running with PID %s.\n' "$pid"
		exit 0
	fi
	rm -f "$pid_file"
fi

log_file="$dir/logs/worker-supervisor.log"
# Launch in a fresh session so the watcher survives the launcher shell exiting
# under stricter PTY/process-tree cleanup environments.
setsid "$HARNESS_BIN/worker-supervisor" "$HARNESS_ENV_FILE" </dev/null >> "$log_file" 2>&1 &
pid=$!
trace_event WORKER_SUPERVISOR_LAUNCH "pid=$pid" "log_file=$log_file" "command=$HARNESS_BIN/worker-supervisor"
for _ in $(seq 1 50); do
	if [[ -f "$pid_file" ]]; then
		trace_event WORKER_SUPERVISOR_STARTED_CONFIRMED "pid=$(cat "$pid_file")"
		printf 'Worker supervisor started with PID %s.\n' "$(cat "$pid_file")"
		printf 'Environment file: %s\n' "$HARNESS_ENV_FILE"
		printf 'Log: %s\n' "$log_file"
		exit 0
	fi
	kill -0 "$pid" 2>/dev/null || break
	sleep 0.1
done
printf 'Worker supervisor failed to start; inspect %s\n' "$log_file" >&2
exit 1
