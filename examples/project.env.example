# Trusted Bash configuration sourced by every harness command.
# Protect this file with: chmod 600 /path/to/project.env

export PROJECT="sample-project"
export REPOSITORY="/path/to/repository"
export SPECIFICATION="$REPOSITORY/work/specification.md"

# Installation containing bin/, lib/, prompts/, and templates/.
export HARNESS_HOME="/opt/coding-agent-fs-harness-v4"
export HARNESS_BIN="$HARNESS_HOME/bin"

# Persistent harness state across logout and reboot.
export HARNESS_ROOT="$HOME/.local/state/coding-harness"

# Scratch task/result markdown is written under /tmp/$PROJECT.

# Manager account and model.
export MANAGER_CODEX_HOME="$HOME/.codex/manager-account"
export MANAGER_CODEX_BIN="$HOME/.local/bin/codex"
MANAGER_CODEX_EXTRA_ARGS=(
  --config model_context_window=272000
  --config model_auto_compact_token_limit=240000
)
export MANAGER_MODEL="gpt-5.5"
# Used after one narrowed retry if a Terra/GPT-5.6 manager turn fails.
export MANAGER_FALLBACK_MODEL="gpt-5.5"
export MANAGER_REASONING_EFFORT="high"
export MANAGER_SANDBOX="workspace-write"

# Worker account and model. This may be the same account as the manager.
export WORKER_CODEX_HOME="$HOME/.codex/worker-account"
export WORKER_CODEX_BIN="$HOME/.local/bin/codex"
WORKER_CODEX_EXTRA_ARGS=(
  --config model_context_window=272000
  --config model_auto_compact_token_limit=240000
)
export WORKER_MODEL="gpt-5.4-mini"
# Used after one narrowed retry if a Terra/GPT-5.6 worker turn fails.
export WORKER_FALLBACK_MODEL="gpt-5.4-mini"
export WORKER_REASONING_EFFORT="high"
export WORKER_SANDBOX="workspace-write"

# Optional final independent audit. Completion is recorded only after its pass.
# These settings inherit the manager Codex account and arguments unless an
# ORACLE_CODEX_HOME, ORACLE_CODEX_BIN, or ORACLE_CODEX_EXTRA_ARGS override is set.
# export ORACLE_MODEL="gpt-5.6-sol"
# export ORACLE_REASONING_EFFORT="xhigh"
# export ORACLE_SANDBOX="danger-full-access"

# Local watcher and lease settings. These do not limit total task duration.
export HARNESS_POLL_SECONDS="2"
export HARNESS_WAIT_SECONDS="300"
export HARNESS_STALE_SECONDS="900"
export HARNESS_USE_INOTIFY="1"
export WORKER_HEARTBEAT_SECONDS="60"

# Provider capacity, rate-limit, service, and network failures retry forever.
# Usage-window/quota exhaustion reports and probes every five minutes.
export HARNESS_PROVIDER_RETRY_SECONDS="60"
export HARNESS_QUOTA_RETRY_SECONDS="300"

# Keep revisions automatic. Set a positive threshold only when this project
# explicitly wants matching zero-progress fingerprints to require intervention.
export HARNESS_MAX_IDENTICAL_BLOCKERS="0"

# Rejected continuations resume one root-scoped worker conversation without
# keeping a process alive. Rotate periodically, or set 0 for no turn-count
# rotation. A manager assignment may request `Worker-Context: FRESH` earlier.
export HARNESS_REUSE_WORKER_THREADS="1"
export HARNESS_WORKER_THREAD_MAX_REJECTIONS="8"

# High-progress revisions may perform a bounded diagnose/fix/retest loop on one
# focused root acceptance smoke. Set ENABLED=0 to retain single-attempt turns.
export HARNESS_CLOSURE_MODE_ENABLED="1"
export HARNESS_CLOSURE_MODE_MIN_PROGRESS="95"
export HARNESS_CLOSURE_MODE_MAX_FIXES="2"
export HARNESS_CLOSURE_MODE_MAX_SMOKE_RUNS="3"

# Correctly progressing turns and revisions are unlimited by default. Set a
# nonzero watchdog only when this project explicitly wants one.
export HARNESS_CODEX_WALL_TIMEOUT_SECONDS="0"
export HARNESS_CODEX_IDLE_TIMEOUT_SECONDS="0"
export HARNESS_CODEX_KILL_GRACE_SECONDS="15"
